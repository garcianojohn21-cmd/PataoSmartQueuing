@{
    var adminName = Context.Session.GetString("AdminName");
    var adminRole = Context.Session.GetString("AdminRole");
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --navy: #1E3A5F;
            --navy-light: #2C5282;
            --green: #22C55E;
            --green-dark: #16A34A;
            --green-pale: #DCFCE7;
            --white: #FFFFFF;
            --off-white: #F9FAFB;
            --gray-200: #E5E7EB;
            --gray-400: #9CA3AF;
            --gray-600: #4B5563;
            --gray-700: #374151;
            --border-green: #BBF7D0;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            --nav-gradient: linear-gradient(135deg, #1E3A5F 0%, #16A34A 100%);
            --green-gradient: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
            --sidebar-width: 280px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, var(--green-pale) 0%, var(--white) 50%, var(--green-pale) 100%);
            background-attachment: fixed;
            color: var(--navy);
        }

        #wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ── */
        #sidebar-wrapper {
            width: var(--sidebar-width);
            background: var(--nav-gradient);
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: rgba(255, 255, 255, 0.5) rgba(0, 0, 0, 0.2);
            box-shadow: 4px 0 20px rgba(22, 163, 74, 0.2);
            z-index: 1000;
        }

            /* Scrollbar styling */
            #sidebar-wrapper::-webkit-scrollbar {
                width: 10px;
            }

            #sidebar-wrapper::-webkit-scrollbar-track {
                background: rgba(0, 0, 0, 0.1);
                border-radius: 5px;
            }

            #sidebar-wrapper::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.3);
                border-radius: 5px;
            }

                #sidebar-wrapper::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 255, 255, 0.5);
                }

        .sidebar-heading {
            padding: 2rem 1.5rem;
            font-size: 1.4rem;
            color: var(--white);
            border-bottom: 2px solid rgba(255, 255, 255, 0.2);
            background: rgba(0, 0, 0, 0.15);
            display: flex;
            align-items: center;
            gap: 1rem;
            font-weight: 800;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
        }

            .sidebar-heading i {
                font-size: 1.8rem;
            }

        .list-group-flush {
            padding: 1rem 0;
        }

        .list-group-item {
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.9);
            padding: 1rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s ease;
            margin: 0.25rem 0.75rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 1rem;
            font-size: 0.95rem;
        }

            .list-group-item i {
                width: 22px;
                text-align: center;
                font-size: 1.1rem;
            }

            .list-group-item:hover {
                background: rgba(255, 255, 255, 0.15);
                color: var(--white);
                transform: translateX(5px);
            }

            .list-group-item.active {
                background: var(--white);
                color: var(--green-dark);
                font-weight: 700;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
            }

        .role-badge {
            padding: 0.35rem 0.85rem;
            background: linear-gradient(135deg, #FCD34D 0%, #FBBF24 100%);
            color: #78350F;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            margin-left: auto;
            box-shadow: 0 2px 8px rgba(252, 211, 77, 0.3);
        }

        /* ── PAGE CONTENT ── */
        #page-content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── TOP NAVBAR ── */
        .admin-navbar {
            background: var(--white);
            padding: 1.25rem 2rem;
            box-shadow: 0 2px 10px rgba(22, 163, 74, 0.1);
            border-bottom: 2px solid var(--border-green);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .navbar-brand-admin {
            display: flex;
            align-items: center;
            gap: 1rem;
            color: var(--green-dark);
            font-weight: 800;
            font-size: 1.3rem;
            text-shadow: 1px 1px 2px rgba(22, 163, 74, 0.1);
        }

            .navbar-brand-admin i {
                width: 45px;
                height: 45px;
                background: var(--green-gradient);
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--white);
                font-size: 1.3rem;
                box-shadow: 0 3px 10px rgba(22, 163, 74, 0.3);
            }

        .admin-info {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: linear-gradient(135deg, var(--green-pale) 0%, var(--white) 100%);
            padding: 0.75rem 1.25rem;
            border-radius: 50px;
            border: 2px solid var(--border-green);
        }

        .admin-avatar {
            width: 40px;
            height: 40px;
            background: var(--green-gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-size: 1.2rem;
            box-shadow: 0 3px 10px rgba(22, 163, 74, 0.3);
        }

        .admin-details {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .admin-name {
            color: var(--green-dark);
            font-weight: 700;
            font-size: 0.95rem;
        }

        .admin-role-badge {
            font-size: 0.75rem;
            padding: 0.25rem 0.65rem;
            border-radius: 12px;
            font-weight: 700;
            display: inline-block;
            width: fit-content;
        }

            .admin-role-badge.super {
                background: linear-gradient(135deg, #FCD34D 0%, #FBBF24 100%);
                color: #78350F;
                box-shadow: 0 2px 8px rgba(252, 211, 77, 0.3);
            }

            .admin-role-badge.regular {
                background: linear-gradient(135deg, var(--green-pale) 0%, var(--border-green) 100%);
                color: var(--green-dark);
                box-shadow: 0 2px 8px rgba(22, 163, 74, 0.2);
            }

        .dropdown-toggle-admin {
            background: var(--white);
            border: 2px solid var(--border-green);
            color: var(--green-dark);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1.1rem;
        }

            .dropdown-toggle-admin:hover {
                background: var(--green-gradient);
                color: var(--white);
                border-color: var(--green-dark);
                transform: scale(1.05);
            }

        .dropdown-menu {
            border: 2px solid var(--border-green);
            box-shadow: 0 8px 25px rgba(22, 163, 74, 0.15);
            border-radius: 15px;
            padding: 0.5rem;
            margin-top: 0.5rem;
            background: var(--white);
        }

        .dropdown-item {
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--navy);
            font-size: 0.95rem;
        }

            .dropdown-item i {
                width: 20px;
                text-align: center;
                font-size: 1rem;
                color: var(--green-dark);
            }

            .dropdown-item:hover {
                background: linear-gradient(135deg, var(--green-pale) 0%, var(--border-green) 100%);
                color: var(--green-dark);
                transform: translateX(3px);
            }

            .dropdown-item.text-danger {
                color: #DC2626;
            }

                .dropdown-item.text-danger i {
                    color: #DC2626;
                }

                .dropdown-item.text-danger:hover {
                    background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
                    color: #DC2626;
                }

        /* ── MAIN CONTENT ── */
        .container-fluid {
            padding: 2rem;
        }

        /* ── FOOTER ── */
        .admin-footer {
            background: var(--white);
            padding: 1.5rem;
            text-align: center;
            color: var(--gray-600);
            border-top: 2px solid var(--border-green);
            margin-top: auto;
            font-weight: 600;
            font-size: 0.95rem;
        }

        /* ── MOBILE TOGGLE ── */
        .mobile-menu-toggle {
            display: none;
            background: var(--green-gradient);
            border: none;
            color: var(--white);
            width: 45px;
            height: 45px;
            border-radius: 12px;
            font-size: 1.3rem;
            cursor: pointer;
            box-shadow: 0 3px 10px rgba(22, 163, 74, 0.3);
            transition: all 0.3s ease;
        }

            .mobile-menu-toggle:hover {
                transform: scale(1.05);
                box-shadow: 0 5px 15px rgba(22, 163, 74, 0.4);
            }

        /* ── RESPONSIVE ── */
        @@media (max-width: 992px) {
            #sidebar-wrapper

        {
            left: -280px;
            transition: left 0.3s ease;
        }

        #sidebar-wrapper.active {
            left: 0;
        }

        #page-content-wrapper {
            margin-left: 0;
        }

        .mobile-menu-toggle {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .navbar-brand-admin {
            font-size: 1.1rem;
        }

        .admin-info {
            padding: 0.5rem 1rem;
        }

        .admin-name {
            display: none;
        }

        .admin-navbar {
            padding: 1rem 1.5rem;
        }

        }

        @@media (max-width: 576px) {
            .navbar-brand-admin span

        {
            display: none;
        }

        .admin-role-badge {
            display: none;
        }

        .admin-navbar {
            padding: 0.75rem 1rem;
        }

        .container-fluid {
            padding: 1rem;
        }

        }

        /* ── OVERLAY FOR MOBILE ── */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

            .sidebar-overlay.active {
                display: block;
            }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">

        <!-- Sidebar Overlay (Mobile) -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- ── SIDEBAR ── -->
        <div id="sidebar-wrapper">
            <div class="sidebar-heading">
                <i class="bi bi-shield-check"></i>
                <span>Admin Panel</span>
            </div>
            <div class="list-group list-group-flush">

                <a asp-controller="Admin" asp-action="Dashboard"
                   class="list-group-item @(currentAction == "Dashboard" ? "active" : "")">
                    <i class="bi bi-graph-up"></i>
                    <span>Dashboard</span>
                </a>

                <a asp-controller="Admin" asp-action="CreateQueue"
                   class="list-group-item @(currentAction == "CreateQueue" ? "active" : "")">
                    <i class="bi bi-plus-circle"></i>
                    <span>Create Queue</span>
                </a>

                <a asp-controller="Admin" asp-action="ManageQueues"
                   class="list-group-item @(currentAction == "ManageQueues" ? "active" : "")">
                    <i class="bi bi-list-check"></i>
                    <span>Manage Queues</span>
                </a>

                <a asp-controller="Admin" asp-action="UnservedList"
                   class="list-group-item @(currentAction == "UnservedList" ? "active" : "")">
                    <i class="bi bi-person-x"></i>
                    <span>Unserved List</span>
                </a>

                <a asp-controller="Admin" asp-action="Archive"
                   class="list-group-item @(currentAction == "Archive" ? "active" : "")">
                    <i class="bi bi-archive"></i>
                    <span>Archive</span>
                </a>

                <a asp-controller="Admin" asp-action="DoneStudent"
                   class="list-group-item @(currentAction == "DoneStudent" ? "active" : "")">
                    <i class="bi bi-check-circle"></i>
                    <span>Done Students</span>
                </a>

                <a asp-controller="Admin" asp-action="LiveView"
                   class="list-group-item @(currentAction == "LiveView" ? "active" : "")">
                    <i class="bi bi-eye"></i>
                    <span>Live View</span>
                </a>

                @if (adminRole == "SuperAdmin")
                {
                    <a asp-controller="Admin" asp-action="ManageAdmins"
                       class="list-group-item @(currentAction == "ManageAdmins" ? "active" : "")">
                        <i class="bi bi-people-fill"></i>
                        <span>Manage Admins</span>
                        <span class="role-badge">SUPER</span>
                    </a>
                }

                <a asp-controller="Admin" asp-action="Reports"
                   class="list-group-item @(currentAction == "Reports" ? "active" : "")">
                    <i class="bi bi-bar-chart"></i>
                    <span>Reports</span>
                </a>

                @if (adminRole == "SuperAdmin")
                {
                    <a asp-controller="Admin" asp-action="Register"
                       class="list-group-item @(currentAction == "Register" ? "active" : "")">
                        <i class="bi bi-person-plus"></i>
                        <span>Register Admin</span>
                        <span class="role-badge">SUPER</span>
                    </a>

                    <a asp-controller="Admin" asp-action="ChangeSearchToken"
                       class="list-group-item @(currentAction == "ChangeSearchToken" ? "active" : "")">
                        <i class="bi bi-key"></i>
                        <span>Portal Token</span>
                        <span class="role-badge">SUPER</span>
                    </a>
                }

                <hr style="border-color: rgba(255, 255, 255, 0.2); margin: 1rem 0.75rem;">

                <a asp-controller="Admin" asp-action="Settings"
                   class="list-group-item @(currentAction == "Settings" ? "active" : "")">
                    <i class="bi bi-gear"></i>
                    <span>Settings</span>
                </a>

            </div>
        </div>

        <!-- ── PAGE CONTENT ── -->
        <div id="page-content-wrapper">

            <!-- ── TOP NAVBAR ── -->
            <nav class="admin-navbar">
                <div class="container-fluid p-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <!-- Left: Menu Toggle & Brand -->
                        <div class="d-flex align-items-center gap-3">
                            <button class="mobile-menu-toggle" id="menuToggle">
                                <i class="bi bi-list"></i>
                            </button>
                            <div class="navbar-brand-admin">
                                <i class="bi bi-building"></i>
                                <span>Patao NHS Smart Queuing</span>
                            </div>
                        </div>

                        <!-- Right: Admin Info & Dropdown -->
                        <div class="d-flex align-items-center gap-3">
                            <div class="admin-info">
                                <div class="admin-avatar">
                                    <i class="bi bi-shield-fill"></i>
                                </div>
                                <div class="admin-details">
                                    <div class="admin-name">@adminName</div>
                                    @if (adminRole == "SuperAdmin")
                                    {
                                        <span class="admin-role-badge super">SUPER ADMIN</span>
                                    }
                                    else
                                    {
                                        <span class="admin-role-badge regular">ADMIN</span>
                                    }
                                </div>
                            </div>

                            <div class="dropdown">
                                <button class="dropdown-toggle-admin" type="button" id="dropdownMenuLink"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuLink">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Notifications">
                                            <i class="bi bi-bell"></i> Notifications
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Settings">
                                            <i class="bi bi-gear"></i> Settings
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Admin" asp-action="Logout"
                                           onclick="return confirm('Are you sure you want to logout?');">
                                            <i class="bi bi-box-arrow-left"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- ── MAIN CONTENT ── -->
            <div class="container-fluid">
                @RenderBody()
            </div>

            <!-- ── FOOTER ── -->
            <footer class="admin-footer">
                <small>
                    <i class="bi bi-c-circle me-1"></i>
                    @DateTime.Now.Year Patao NHS Smart Queuing System - Admin Panel
                </small>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Mobile menu toggle
        const menuToggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar-wrapper');
        const overlay = document.getElementById('sidebarOverlay');

        if (menuToggle) {
            menuToggle.addEventListener('click', function() {
                sidebar.classList.toggle('active');
                overlay.classList.toggle('active');
            });
        }

        if (overlay) {
            overlay.addEventListener('click', function() {
                sidebar.classList.remove('active');
                overlay.classList.remove('active');
            });
        }

        // Close sidebar when clicking menu items on mobile
        document.querySelectorAll('.list-group-item').forEach(item => {
            item.addEventListener('click', function() {
                if (window.innerWidth <= 992) {
                    sidebar.classList.remove('active');
                    overlay.classList.remove('active');
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>

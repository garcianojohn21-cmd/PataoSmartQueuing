@{
    ViewBag.Title = "Patao NHS Smart Queuing System";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --navy: #0D1B2A;
        --navy-mid: #1B2E44;
        --navy-light: #243A52;
        --green: #22C55E;
        --green-dark: #16A34A;
        --green-light: #4ADE80;
        --green-pale: #F0FDF4;
        --green-gradient: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
        --navy-gradient: linear-gradient(135deg, #0D1B2A 0%, #1B2E44 100%);
        --white: #FFFFFF;
        --border: rgba(34, 197, 94, 0.25);
        --shadow: 0 8px 32px rgba(13, 27, 42, 0.18);
        --shadow-green: 0 6px 24px rgba(34, 197, 94, 0.25);
    }

    body {
        background: linear-gradient(160deg, #f0fdf4 0%, #e0f2fe 100%);
        min-height: 100vh;
    }

    /* ── HERO ── */
    .hero-section {
        background: var(--navy-gradient);
        color: var(--white);
        padding: 70px 0 60px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
    }

        .hero-section::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--green-gradient);
        }

        .hero-section::before {
            content: '🦜';
            position: absolute;
            font-size: 260px;
            opacity: 0.07;
            right: -40px;
            top: -40px;
            animation: float 6s ease-in-out infinite;
            line-height: 1;
        }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-18px);
        }
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 14px;
        letter-spacing: -0.5px;
    }

    .hero-subtitle {
        font-size: 1.25rem;
        opacity: 0.85;
        margin-bottom: 10px;
        font-weight: 500;
    }

    .hero-lead {
        font-size: 1rem;
        opacity: 0.7;
        margin: 0;
    }

    /* ── NOTIFICATION MODAL ── */
    .notification-modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.55);
        z-index: 9999;
        animation: fadeIn 0.3s ease;
    }

        .notification-modal-overlay.show {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(40px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }
    }

    .notification-modal {
        background: var(--white);
        border-radius: 22px;
        box-shadow: var(--shadow);
        border: 2px solid var(--border);
        max-width: 420px;
        width: 100%;
        overflow: hidden;
        animation: slideUp 0.4s ease;
    }

    .notification-modal-header {
        background: linear-gradient(160deg, #fff 60%, var(--green-pale) 100%);
        padding: 32px 28px 24px;
        text-align: center;
    }

    .notification-modal-icon {
        font-size: 60px;
        margin-bottom: 14px;
        animation: bounce 2s infinite;
        display: block;
    }

    .notification-modal-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .notification-modal-text {
        font-size: 0.95rem;
        color: #6B7280;
        line-height: 1.6;
    }

    .notification-modal-buttons {
        display: flex;
        border-top: 2px solid var(--border);
    }

    .notification-modal-btn {
        flex: 1;
        padding: 18px;
        border: none;
        background: none;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        font-size: 13px;
    }

        .notification-modal-btn:first-child {
            border-right: 2px solid var(--border);
            color: #6B7280;
        }

            .notification-modal-btn:first-child:hover {
                background: #F3F4F6;
            }

        .notification-modal-btn:last-child {
            background: var(--green-gradient);
            color: var(--white);
        }

            .notification-modal-btn:last-child:hover {
                filter: brightness(1.08);
            }

        .notification-modal-btn:active {
            transform: scale(0.97);
        }

    /* ── ROLE CARDS ── */
    .role-card {
        background: var(--white);
        border-radius: 22px;
        padding: 36px 28px;
        text-align: center;
        box-shadow: var(--shadow);
        border: 2px solid var(--border);
        height: 100%;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .role-card::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 4px;
        }

        .role-card.admin-card::before {
            background: linear-gradient(90deg, #0EA5E9, #0284C7);
        }

        .role-card.student-card::before {
            background: var(--green-gradient);
        }

        .role-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 48px rgba(13,27,42,0.2);
        }

    .role-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 2rem;
        animation: bounce 2.5s infinite;
    }

    .admin-card .role-icon-wrap {
        background: rgba(14,165,233,0.1);
        color: #0284C7;
        border: 2px solid rgba(14,165,233,0.25);
    }

    .student-card .role-icon-wrap {
        background: rgba(34,197,94,0.1);
        color: var(--green-dark);
        border: 2px solid var(--border);
    }

    .role-title {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 12px;
    }

    .role-description {
        color: #6B7280;
        margin-bottom: 20px;
        font-size: 0.95rem;
        line-height: 1.65;
    }

    .role-features {
        text-align: left;
        list-style: none;
        padding: 0;
        margin: 0 0 28px 0;
    }

        .role-features li {
            padding: 9px 0;
            color: #374151;
            font-size: 0.93rem;
            font-weight: 500;
            border-bottom: 1px solid rgba(34,197,94,0.1);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .role-features li:last-child {
                border-bottom: none;
            }

    .admin-card .role-features li i {
        color: #0284C7;
    }

    .student-card .role-features li i {
        color: var(--green-dark);
    }

    .btn-role {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 40px;
        font-size: 0.88rem;
        font-weight: 800;
        border-radius: 14px;
        border: none;
        transition: all 0.25s;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        text-decoration: none;
        width: 100%;
    }

    .btn-admin {
        background: linear-gradient(135deg, #0EA5E9, #0284C7);
        color: var(--white);
        box-shadow: 0 6px 20px rgba(14,165,233,0.35);
    }

        .btn-admin:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(14,165,233,0.5);
            color: var(--white);
        }

    .btn-student {
        background: var(--green-gradient);
        color: var(--white);
        box-shadow: var(--shadow-green);
    }

        .btn-student:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(34,197,94,0.45);
            color: var(--white);
        }

    .register-link {
        display: block;
        margin-top: 12px;
        font-size: 13px;
        color: #6B7280;
    }

        .register-link a {
            color: var(--green-dark);
            font-weight: 700;
            text-decoration: none;
        }

            .register-link a:hover {
                text-decoration: underline;
            }

    /* ── STATS STRIP ── */
    .stats-section {
        background: var(--navy-gradient);
        border-radius: 22px;
        padding: 40px 0;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

        .stats-section::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--green-gradient);
        }

        .stats-section::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(34,197,94,0.12) 0%, transparent 70%);
        }

    .stat-item {
        text-align: center;
        padding: 16px;
        position: relative;
        z-index: 1;
    }

    .stat-icon-wrap {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: rgba(34,197,94,0.15);
        border: 2px solid rgba(34,197,94,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 1.4rem;
        color: var(--green-light);
    }

    .stat-label {
        font-size: 0.88rem;
        color: rgba(255,255,255,0.75);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* ── FEATURES ── */
    .features-section {
        background: var(--white);
        border-radius: 22px;
        box-shadow: var(--shadow);
        border: 2px solid var(--border);
        padding: 48px 0;
        margin-bottom: 36px;
        overflow: hidden;
    }

    .features-title {
        font-weight: 800;
        font-size: 1.8rem;
        color: var(--navy);
        margin-bottom: 8px;
    }

    .features-subtitle {
        color: #6B7280;
        font-size: 0.95rem;
        margin-bottom: 40px;
    }

    .feature-item {
        text-align: center;
        padding: 24px 20px;
        transition: transform 0.2s;
        border-radius: 16px;
    }

        .feature-item:hover {
            transform: translateY(-4px);
        }

    .feature-icon-wrap {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        background: rgba(34,197,94,0.1);
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 1.5rem;
        color: var(--green-dark);
        transition: all 0.2s;
    }

    .feature-item:hover .feature-icon-wrap {
        background: var(--green-gradient);
        color: var(--white);
        border-color: transparent;
        box-shadow: var(--shadow-green);
    }

    .feature-title {
        font-size: 1rem;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 8px;
    }

    .feature-text {
        color: #6B7280;
        font-size: 0.88rem;
        line-height: 1.6;
    }

    /* ── MOBILE ── */
    @@media (max-width: 767.98px) {
        .hero-section {
            padding: 44px 0 38px;
            margin-bottom: 20px;
        }

        .hero-title {
            font-size: 1.75rem;
        }

        .hero-subtitle {
            font-size: 1rem;
        }

        .hero-lead {
            font-size: 0.88rem;
        }

        .hero-section::before {
            font-size: 150px;
            right: -16px;
            top: -16px;
        }

        .role-card {
            padding: 24px 18px;
            margin-bottom: 0;
            border-radius: 18px;
        }

        .role-title {
            font-size: 1.25rem;
        }

        .role-description {
            font-size: 0.85rem;
            margin-bottom: 14px;
        }

        .role-features li {
            font-size: 0.83rem;
            padding: 7px 0;
            gap: 8px;
        }

        .role-icon-wrap {
            width: 60px;
            height: 60px;
            font-size: 1.6rem;
            margin-bottom: 14px;
        }

        .btn-role {
            padding: 12px 20px;
            font-size: 0.8rem;
            border-radius: 12px;
        }

        .register-link {
            font-size: 12px;
        }

        .stats-section {
            padding: 24px 0;
            margin-bottom: 20px;
            border-radius: 18px;
        }

        .stat-icon-wrap {
            width: 44px;
            height: 44px;
            font-size: 1.1rem;
        }

        .stat-label {
            font-size: 0.72rem;
            letter-spacing: 0.3px;
        }

        .stat-item {
            padding: 10px 8px;
        }

        .features-section {
            padding: 28px 0;
            border-radius: 18px;
            margin-bottom: 20px;
        }

        .features-title {
            font-size: 1.35rem;
        }

        .features-subtitle {
            font-size: 0.85rem;
            margin-bottom: 24px;
        }

        .feature-item {
            padding: 14px 10px;
        }

        .feature-icon-wrap {
            width: 46px;
            height: 46px;
            font-size: 1.1rem;
            border-radius: 12px;
            margin-bottom: 10px;
        }

        .feature-title {
            font-size: 0.85rem;
            margin-bottom: 5px;
        }

        .feature-text {
            font-size: 0.78rem;
        }

        .notification-modal {
            border-radius: 18px;
        }

        .notification-modal-header {
            padding: 24px 20px 18px;
        }

        .notification-modal-icon {
            font-size: 46px;
            margin-bottom: 10px;
        }

        .notification-modal-title {
            font-size: 1.1rem;
        }

        .notification-modal-text {
            font-size: 0.85rem;
        }

        .notification-modal-btn {
            padding: 15px;
            font-size: 12px;
        }
    }

    @@media (max-width: 400px) {
        .hero-title {
            font-size: 1.45rem;
        }

        .role-title {
            font-size: 1.1rem;
        }
    }
</style>

<!-- Notification Permission Modal -->
<div class="notification-modal-overlay" id="notificationModalOverlay">
    <div class="notification-modal">
        <div class="notification-modal-header">
            <span class="notification-modal-icon">🔔</span>
            <h3 class="notification-modal-title">"Patao NHS" Would Like To Send You Notifications</h3>
            <p class="notification-modal-text">
                Notifications may include alerts, sounds, and icon badges. These can be configured in Settings.
            </p>
        </div>
        <div class="notification-modal-buttons">
            <button class="notification-modal-btn" onclick="denyNotifications()">Don't Allow</button>
            <button class="notification-modal-btn" onclick="allowNotifications()">Allow</button>
        </div>
    </div>
</div>

<!-- Hero -->
<div class="hero-section">
    <div class="container">
        <div class="hero-content text-center">
            <h1 class="hero-title">Patao NHS Smart Queuing</h1>
            <p class="hero-subtitle">Modern, Efficient, and Fair Queue Management System</p>
            <p class="hero-lead">Say goodbye to long lines and chaos. Experience organized, digital queuing today!</p>
        </div>
    </div>
</div>

<div class="container">

    <!-- Role Cards -->
    <div class="row mb-4 g-3">

        <!-- Admin Portal -->
        <div class="col-md-6 col-12">
            <div class="role-card admin-card">
                <div class="role-icon-wrap">
                    <i class="fas fa-user-shield"></i>
                </div>
                <h2 class="role-title">Admin Portal</h2>
                <p class="role-description">
                    Manage queues, monitor students, and streamline the enrollment process with powerful admin tools.
                </p>
                <ul class="role-features">
                    <li><i class="fas fa-check-circle"></i> Create &amp; manage queues</li>
                    <li><i class="fas fa-check-circle"></i> Track student status in real-time</li>
                    <li><i class="fas fa-check-circle"></i> Send notifications &amp; announcements</li>
                    <li><i class="fas fa-check-circle"></i> Generate reports &amp; analytics</li>
                    <li><i class="fas fa-check-circle"></i> Archive completed queues</li>
                </ul>
            </div>
        </div>

        <!-- Student Portal -->
        <div class="col-md-6 col-12">
            <div class="role-card student-card">
                <div class="role-icon-wrap">
                    <i class="fas fa-user-graduate"></i>
                </div>
                <h2 class="role-title">Student Portal</h2>
                <p class="role-description">
                    Join queues, track your position, and receive notifications when it's your turn — all from your device!
                </p>
                <ul class="role-features">
                    <li><i class="fas fa-check-circle"></i> Join queues with unique codes</li>
                    <li><i class="fas fa-check-circle"></i> Track your queue position live</li>
                    <li><i class="fas fa-check-circle"></i> Receive turn notifications</li>
                    <li><i class="fas fa-check-circle"></i> View queue history</li>
                    <li><i class="fas fa-check-circle"></i> Secure PIN verification</li>
                </ul>
                <a href="@Url.Action("Login", "Account")" class="btn-role btn-student">
                    <i class="fas fa-sign-in-alt"></i> Student Login
                </a>
                <span class="register-link">
                    New student? <a href="@Url.Action("Register", "Account")">Register here</a>
                </span>
            </div>
        </div>

    </div>

    <!-- Stats Strip -->
    <div class="stats-section">
        <div class="container">
            <div class="row g-0">
                <div class="col-6 col-md-3">
                    <div class="stat-item">
                        <div class="stat-icon-wrap"><i class="fas fa-clock"></i></div>
                        <div class="stat-label">Real-Time Updates</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="stat-item">
                        <div class="stat-icon-wrap"><i class="fas fa-mobile-alt"></i></div>
                        <div class="stat-label">Mobile Friendly</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="stat-item">
                        <div class="stat-icon-wrap"><i class="fas fa-bell"></i></div>
                        <div class="stat-label">Push Notifications</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="stat-item">
                        <div class="stat-icon-wrap"><i class="fas fa-shield-alt"></i></div>
                        <div class="stat-label">Secure &amp; Fair</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Features -->
    <div class="features-section">
        <div class="container">
            <h2 class="features-title text-center">Why Use Our System?</h2>
            <p class="features-subtitle text-center">Everything you need for a smooth, fair queuing experience</p>
            <div class="row g-2">
                <div class="col-6 col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon-wrap"><i class="fas fa-list-ol"></i></div>
                        <h3 class="feature-title">Organized Queuing</h3>
                        <p class="feature-text">No more confusion or line-cutting. Everyone gets a fair queue number.</p>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon-wrap"><i class="fas fa-sun"></i></div>
                        <h3 class="feature-title">Wait Comfortably</h3>
                        <p class="feature-text">Monitor your position from anywhere. No need to stand in the heat!</p>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon-wrap"><i class="fas fa-bolt"></i></div>
                        <h3 class="feature-title">Lightning Fast</h3>
                        <p class="feature-text">Instant updates via SignalR. Know exactly when it's your turn.</p>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon-wrap"><i class="fas fa-chart-line"></i></div>
                        <h3 class="feature-title">Admin Analytics</h3>
                        <p class="feature-text">Track performance, view reports, and export queue data easily.</p>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon-wrap"><i class="fas fa-lock"></i></div>
                        <h3 class="feature-title">PIN Verification</h3>
                        <p class="feature-text">Secure PIN codes ensure only the right student is served.</p>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon-wrap"><i class="fas fa-archive"></i></div>
                        <h3 class="feature-title">History &amp; Archive</h3>
                        <p class="feature-text">Complete record-keeping with searchable queue archives.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (!("Notification" in window)) return;
            if (Notification.permission === "default") {
                setTimeout(function () {
                    document.getElementById("notificationModalOverlay").classList.add("show");
                }, 2000);
            }
        });

        function allowNotifications() {
            Notification.requestPermission().then(function (permission) {
                document.getElementById("notificationModalOverlay").classList.remove("show");
                if (permission === "granted") {
                    new Notification("Welcome to Patao NHS! 🦜", {
                        body: "You'll receive real-time queue updates and alerts.",
                        icon: "/images/notification-icon.png"
                    });
                }
            });
        }

        function denyNotifications() {
            document.getElementById("notificationModalOverlay").classList.remove("show");
        }

        document.getElementById("notificationModalOverlay").addEventListener("click", function (e) {
            if (e.target === this) denyNotifications();
        });
    </script>
}

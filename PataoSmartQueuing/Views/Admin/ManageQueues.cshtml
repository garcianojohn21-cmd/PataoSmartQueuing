@model IEnumerable<PataoSmartQueuing.Models.Queue>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Queues";
}

<style>
    :root {
        --parakeet-green: #22C55E;
        --parakeet-dark: #16A34A;
        --parakeet-light: #4ADE80;
        --parakeet-pale: #F0FDF4;
        --parakeet-glow: rgba(34, 197, 94, 0.25);
        --parakeet-navy: #1E293B;
        --parakeet-border: rgba(34, 197, 94, 0.3);
        --parakeet-gradient: linear-gradient(135deg, #22C55E, #16A34A);
        --parakeet-shadow: 0 4px 16px rgba(34, 197, 94, 0.2);
        --parakeet-shadow-sm: 0 2px 8px rgba(34, 197, 94, 0.12);
    }

    .parakeet-container {
        background: linear-gradient(135deg, var(--parakeet-pale) 0%, #ffffff 100%);
        box-shadow: 0 0 40px var(--parakeet-glow), 0 8px 32px rgba(34, 197, 94, 0.15);
        border-radius: 16px;
        padding: 30px;
        border: 1.5px solid var(--parakeet-border);
    }

    .parakeet-header {
        background: var(--parakeet-gradient);
        color: white;
        padding: 20px 24px;
        border-radius: 12px;
        box-shadow: var(--parakeet-shadow);
        margin-bottom: 25px;
    }

    .parakeet-title {
        color: white;
        font-weight: 700;
        margin: 0;
    }

    /* ── BUTTONS ── */
    .btn-parakeet {
        background: var(--parakeet-gradient);
        border: none;
        color: white;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        padding: 10px 18px;
        border-radius: 10px;
        transition: all 0.25s;
        box-shadow: var(--parakeet-shadow-sm);
        position: relative;
        overflow: hidden;
    }

        .btn-parakeet::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.4s, height 0.4s;
        }

        .btn-parakeet:hover::before {
            width: 200px;
            height: 200px;
        }

        .btn-parakeet:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(34, 197, 94, 0.4);
            color: white;
        }

        .btn-parakeet:active {
            transform: translateY(0);
        }

    .btn-outline-parakeet {
        border: 1.5px solid var(--parakeet-green);
        color: var(--parakeet-dark);
        background: white;
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.4px;
        padding: 10px 18px;
        border-radius: 10px;
        transition: all 0.25s;
    }

        .btn-outline-parakeet:hover {
            background: var(--parakeet-green);
            color: white;
            transform: translateY(-2px);
            box-shadow: var(--parakeet-shadow-sm);
        }

    /* ── ALERTS ── */
    .parakeet-alert {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 16px;
        font-size: 13.5px;
        font-weight: 500;
        line-height: 1.5;
        background: var(--parakeet-pale);
        color: var(--parakeet-navy);
        border-left: 4px solid var(--parakeet-green);
        box-shadow: var(--parakeet-shadow-sm);
        animation: slideDown 0.3s ease;
    }

    @@keyframes slideDown {
        from

    {
        opacity: 0;
        transform: translateY(-15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .parakeet-alert i {
        color: var(--parakeet-dark);
        font-size: 16px;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .parakeet-alert strong {
        color: var(--parakeet-dark);
    }

    /* ── STAT CARDS ── */
    .stat-card {
        background: white;
        border: 1.5px solid var(--parakeet-border);
        border-radius: 14px;
        padding: 20px;
        box-shadow: var(--parakeet-shadow-sm);
        transition: all 0.25s;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--parakeet-shadow);
            border-color: var(--parakeet-green);
        }

    .stat-icon {
        font-size: 2.2rem;
        color: var(--parakeet-green);
    }

    .stat-number {
        font-size: 2.4rem;
        font-weight: 700;
        color: var(--parakeet-dark);
        margin: 8px 0 4px 0;
    }

    .stat-label {
        color: #64748B;
        font-weight: 500;
        font-size: 0.9rem;
    }

    /* ── FORM CONTROLS ── */
    .form-control, .form-select {
        border: 1.5px solid var(--parakeet-border);
        border-radius: 10px;
        padding: 12px 14px;
        font-size: 14px;
        color: var(--parakeet-navy);
        transition: all 0.25s;
        box-shadow: var(--parakeet-shadow-sm);
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--parakeet-green);
            box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15);
            outline: none;
        }

    /* ── QUEUE CARDS ── */
    .queue-card {
        background: white;
        border: 1.5px solid var(--parakeet-border);
        border-radius: 16px;
        padding: 24px;
        box-shadow: var(--parakeet-shadow-sm);
        transition: all 0.25s;
        margin-bottom: 16px;
    }

        .queue-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--parakeet-shadow);
            border-color: var(--parakeet-green);
        }

    .queue-title {
        color: var(--parakeet-navy);
        font-weight: 700;
        font-size: 1.3rem;
        margin-bottom: 6px;
    }

    /* ── BADGES ── */
    .badge-parakeet {
        background: var(--parakeet-gradient);
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 12px;
        box-shadow: var(--parakeet-shadow-sm);
    }

    .badge-parakeet-outline {
        background: white;
        border: 1.5px solid var(--parakeet-border);
        color: var(--parakeet-dark);
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 12px;
    }

    .pulse-badge {
        animation: pulse-glow 2s infinite;
    }

    @@keyframes pulse-glow {
        0%, 100% {
            opacity: 1;
            box-shadow: 0 2px 8px var(--parakeet-glow);
        }

        50% {
            opacity: 0.85;
            box-shadow: 0 4px 16px var(--parakeet-glow);
        }
    }

    /* ── COPY BUTTONS ── */
    .copy-btn, .copy-link-btn {
        border: 1.5px solid var(--parakeet-border);
        color: var(--parakeet-dark);
        background: white;
        transition: all 0.25s;
        border-radius: 8px;
        padding: 4px 8px;
    }

        .copy-btn:hover, .copy-link-btn:hover {
            background: var(--parakeet-green);
            border-color: var(--parakeet-green);
            color: white;
            transform: scale(1.08);
        }

    /* ── QUEUE INFO ── */
    .queue-info-icon {
        color: var(--parakeet-green);
        margin-right: 5px;
    }

    .queue-link {
        color: var(--parakeet-dark);
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.25s;
    }

        .queue-link:hover {
            color: var(--parakeet-green);
            text-decoration: underline;
        }

    /* ── ACTION BUTTONS ── */
    .btn-group-vertical .btn {
        border-radius: 10px !important;
        margin-bottom: 8px;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.25s;
        padding: 9px 14px;
    }

        .btn-group-vertical .btn:hover {
            transform: translateX(-3px);
        }

    .btn-success {
        background: var(--parakeet-gradient);
        border: none;
        color: white;
    }

        .btn-success:hover {
            background: linear-gradient(135deg, #16A34A, #15803D);
            color: white;
            box-shadow: var(--parakeet-shadow-sm);
        }

    .btn-info {
        background: #0EA5E9;
        border-color: #0284C7;
        color: white;
    }

        .btn-info:hover {
            background: #0284C7;
            color: white;
        }

    .btn-secondary {
        background: #64748B;
        border-color: #475569;
        color: white;
    }

        .btn-secondary:hover {
            background: #475569;
            color: white;
        }

    .btn-outline-primary {
        border: 1.5px solid #3B82F6;
        color: #2563EB;
        background: white;
    }

        .btn-outline-primary:hover {
            background: #3B82F6;
            color: white;
        }

    .btn-outline-warning {
        border: 1.5px solid #F59E0B;
        color: #92400E;
        background: white;
    }

        .btn-outline-warning:hover {
            background: #F59E0B;
            color: white;
        }

    /* ── NO RESULTS ── */
    .no-results {
        background: linear-gradient(135deg, var(--parakeet-pale), white);
        border: 1.5px dashed var(--parakeet-border);
        border-radius: 16px;
        padding: 50px;
        text-align: center;
    }

        .no-results i {
            color: var(--parakeet-green);
            font-size: 3.5rem;
            margin-bottom: 16px;
        }

        .no-results h5 {
            color: var(--parakeet-navy);
            font-weight: 700;
        }

    /* ── MODAL ── */
    .modal-header {
        background: var(--parakeet-gradient);
        color: white;
        border-bottom: none;
        border-radius: 12px 12px 0 0;
    }

    .modal-title {
        font-weight: 700;
    }

    .modal-content {
        border: 1.5px solid var(--parakeet-border);
        border-radius: 14px;
        box-shadow: 0 10px 40px rgba(34, 197, 94, 0.2);
        overflow: hidden;
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 576px) {
        .parakeet-container {
            padding: 16px;
        }

        .parakeet-header {
            padding: 14px 16px;
        }

        .queue-card {
            padding: 16px;
        }

        .no-results {
            padding: 30px 16px;
        }
    }
</style>

<div class="container mt-5">
    @Html.AntiForgeryToken()

    <div class="parakeet-container">
        <!-- Header -->
        <div class="parakeet-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <h2 class="parakeet-title mb-0">
                    <i class="bi bi-list-task me-2"></i> Manage Queues
                </h2>
                <div class="d-flex gap-2 flex-wrap mt-3 mt-md-0">
                    <a asp-action="Archive" class="btn btn-outline-parakeet rounded-3" style="background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.5);color:white;">
                        <i class="bi bi-archive me-1"></i> View Archive
                    </a>
                    <a asp-action="CreateQueue" class="btn rounded-3" style="background:white;color:var(--parakeet-dark);font-weight:700;font-size:13px;letter-spacing:0.4px;">
                        <i class="bi bi-plus-circle me-1"></i> Create New Queue
                    </a>
                </div>
            </div>
        </div>

        <!-- Active Queue Alert -->
        @{
            var activeQueue = Model.FirstOrDefault(q => q.IsActive && !q.IsDone);
        }
        @if (activeQueue != null)
        {
            <div class="parakeet-alert alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span><strong>Currently Active:</strong> @activeQueue.QueueName</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Statistics Summary -->
        @{
            var totalQueues = Model.Count(q => !q.IsDone);
            var activeCount = Model.Count(q => q.IsActive && !q.IsDone);
            var pendingCount = Model.Count(q => !q.IsActive && !q.IsDone);
            var archivedCount = Model.Count(q => q.IsDone);
        }
        <div class="row mb-4 g-3">
            <div class="col-md-3 col-sm-6">
                <div class="stat-card">
                    <div class="text-center">
                        <i class="bi bi-grid-3x3-gap stat-icon"></i>
                        <h3 class="stat-number">@totalQueues</h3>
                        <small class="stat-label">Total Queues</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card">
                    <div class="text-center">
                        <i class="bi bi-broadcast stat-icon"></i>
                        <h3 class="stat-number">@activeCount</h3>
                        <small class="stat-label">In Use</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card">
                    <div class="text-center">
                        <i class="bi bi-hourglass-split stat-icon" style="color:#F59E0B;"></i>
                        <h3 class="stat-number" style="color:#92400E;">@pendingCount</h3>
                        <small class="stat-label">Pending</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="stat-card">
                    <div class="text-center">
                        <i class="bi bi-archive stat-icon" style="color:#94A3B8;"></i>
                        <h3 class="stat-number" style="color:#64748B;">@archivedCount</h3>
                        <small class="stat-label">Archived</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="row mb-4 g-2">
            <div class="col-md-6">
                <input type="text" id="searchBox" class="form-control"
                       placeholder="🔍 Search queues by name, code, or creator...">
            </div>
            <div class="col-md-3">
                <select id="statusFilter" class="form-select">
                    <option value="">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Active">Active</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-parakeet w-100" id="clearFilters">
                    <i class="bi bi-x-circle me-1"></i> Clear Filters
                </button>
            </div>
        </div>

        <!-- Queue Cards -->
        <div id="queueList">
            @{
                var activeQueues = Model.Where(q => !q.IsDone).ToList();
            }
            @if (!activeQueues.Any())
            {
                <div class="no-results">
                    <i class="bi bi-inboxes display-6 d-block"></i>
                    <h5>No active queues</h5>
                    <p class="text-muted">Create your first queue to get started!</p>
                    <a asp-action="CreateQueue" class="btn btn-parakeet mt-3">
                        <i class="bi bi-plus-circle me-1"></i> Create Queue
                    </a>
                </div>
            }
            else
            {
                @foreach (var q in activeQueues)
                {
                    var joinLink = $"{Context.Request.Scheme}://{Context.Request.Host}/Student/JoinQueue?code={q.QueueCode}";
                    var statusText = q.IsActive ? "Active" : "Pending";
                    var badgeClass = q.IsActive ? "badge-parakeet pulse-badge" : "bg-warning text-dark";
                    var studentCount = q.QueueStudents?.Count(qs => qs.Status != "Done") ?? 0;
                    var totalStudents = q.QueueStudents?.Count ?? 0;
                    var canUse = !q.IsActive;
                    var creatorName = $"{q.CreatedByAdmin.FirstName} {q.CreatedByAdmin.LastName}";

                    <div class="queue-card"
                         data-name="@q.QueueName.ToLower()"
                         data-code="@q.QueueCode.ToLower()"
                         data-creator="@creatorName.ToLower()"
                         data-status="@statusText"
                         data-id="@q.QueueID">
                        <div class="row align-items-center">
                            <!-- Left: Info -->
                            <div class="col-lg-8">
                                <h5 class="queue-title">
                                    @q.QueueName
                                    @if (q.IsActive)
                                    {
                                        <span class="badge badge-parakeet pulse-badge ms-2">
                                            <i class="bi bi-broadcast"></i> LIVE
                                        </span>
                                    }
                                </h5>
                                <p class="text-muted mb-3" style="font-size:13.5px;">@q.Description</p>

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge-parakeet-outline">
                                        <i class="bi bi-people me-1"></i> Max: @q.MaxStudents
                                    </span>
                                    <span class="badge bg-info text-white">
                                        <i class="bi bi-person-check me-1"></i> In Queue: @studentCount
                                    </span>
                                    @if (totalStudents > 0)
                                    {
                                        <span class="badge bg-primary text-white">
                                            <i class="bi bi-graph-up me-1"></i> Total: @totalStudents
                                        </span>
                                    }
                                </div>

                                <div class="mb-2">
                                    <i class="bi bi-shield-lock queue-info-icon"></i>
                                    <span class="badge-parakeet-outline">@q.QueueCode</span>
                                    <button class="btn btn-sm copy-btn ms-1"
                                            data-copy="@q.QueueCode"
                                            title="Copy Code">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                </div>

                                <div class="mb-2">
                                    <i class="bi bi-link-45deg queue-info-icon"></i>
                                    <a href="@joinLink" target="_blank" class="queue-link">
                                        Join Link
                                    </a>
                                    <button class="btn btn-sm copy-link-btn ms-1"
                                            data-copy="@joinLink"
                                            title="Copy Link">
                                        <i class="bi bi-link"></i>
                                    </button>
                                </div>

                                <div class="text-muted small">
                                    <i class="bi bi-person-circle queue-info-icon"></i>
                                    @creatorName |
                                    <i class="bi bi-calendar-check queue-info-icon ms-2"></i>
                                    @q.DateCreated.ToString("MMM dd, yyyy hh:mm tt")
                                </div>
                            </div>

                            <!-- Right: Actions -->
                            <div class="col-lg-4 mt-3 mt-lg-0">
                                <div class="d-flex flex-column align-items-end gap-2">
                                    <span class="badge @badgeClass">@statusText</span>

                                    <div class="btn-group-vertical w-100">
                                        @if (canUse)
                                        {
                                            <button type="button"
                                                    class="btn btn-success use-btn"
                                                    data-id="@q.QueueID"
                                                    data-name="@q.QueueName">
                                                <i class="bi bi-play-circle"></i> Use Queue
                                            </button>
                                        }
                                        @if (q.IsActive)
                                        {
                                            <a asp-action="StudentInQueue"
                                               asp-route-queueId="@q.QueueID"
                                               class="btn btn-info text-white">
                                                <i class="bi bi-eye"></i> View Queue
                                            </a>
                                            <button type="button"
                                                    class="btn btn-secondary mark-done-btn"
                                                    data-id="@q.QueueID"
                                                    data-name="@q.QueueName">
                                                <i class="bi bi-check2-circle"></i> Mark Done
                                            </button>
                                        }
                                        @if (!q.IsActive)
                                        {
                                            <a asp-action="EditQueue"
                                               asp-route-id="@q.QueueID"
                                               class="btn btn-outline-primary">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </a>
                                        }
                                        <button type="button"
                                                class="btn btn-outline-warning archive-btn"
                                                data-id="@q.QueueID"
                                                data-name="@q.QueueName"
                                                @(q.IsActive ? "disabled" : "")>
                                            <i class="bi bi-archive"></i> Archive
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- No Results Message -->
        <div id="noResults" class="no-results" style="display: none;">
            <i class="bi bi-search display-6 d-block"></i>
            <h5>No queues found</h5>
            <p class="text-muted">Try adjusting your search or filter criteria</p>
            <button class="btn btn-outline-parakeet" id="clearFiltersBtn">
                <i class="bi bi-x-circle me-1"></i> Clear Filters
            </button>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Confirm Action</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-parakeet" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-parakeet" id="confirmBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        let confirmModal, confirmAction;

        document.addEventListener('DOMContentLoaded', function () {
            confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        });

        function showConfirm(title, message, action) {
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalBody').innerHTML = message;
            confirmAction = action;
            confirmModal.show();
        }

        document.getElementById('confirmBtn').addEventListener('click', function () {
            if (confirmAction) confirmAction();
            confirmModal.hide();
        });

        // Copy to clipboard
        document.querySelectorAll(".copy-btn, .copy-link-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                const textToCopy = this.dataset.copy;
                navigator.clipboard.writeText(textToCopy).then(() => {
                    const original = this.innerHTML;
                    this.innerHTML = "<i class='bi bi-check-lg text-success'></i>";
                    setTimeout(() => this.innerHTML = original, 2000);
                }).catch(err => {
                    console.error('Copy failed:', err);
                    alert('Failed to copy to clipboard');
                });
            });
        });

        // Use Queue
        document.querySelectorAll(".use-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                const queueId   = this.dataset.id;
                const queueName = this.dataset.name;
                showConfirm(
                    'Activate Queue',
                    `Are you sure you want to activate <strong>${queueName}</strong>?<br><br>This will make it the active queue for students to join.`,
                    () => activateQueue(queueId)
                );
            });
        });

        function activateQueue(queueId) {
            fetch(`/Admin/UseQueueAjax/${queueId}`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "RequestVerificationToken": token }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) { location.reload(); }
                else { alert(data.message); }
            })
            .catch(err => { console.error("Error:", err); alert("An error occurred. Please try again."); });
        }

        // Mark Done
        document.querySelectorAll(".mark-done-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                const queueId   = this.dataset.id;
                const queueName = this.dataset.name;
                showConfirm(
                    'Mark Queue as Done',
                    `Are you sure you want to mark <strong>${queueName}</strong> as done?<br><br>This will deactivate the queue and move it to the archive.`,
                    () => markDone(queueId)
                );
            });
        });

        function markDone(queueId) {
            fetch(`/Admin/DoneQueueAjax/${queueId}`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "RequestVerificationToken": token }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) { location.reload(); }
                else { alert(data.message); }
            })
            .catch(err => { console.error("Error:", err); alert("An error occurred. Please try again."); });
        }

        // Archive Queue
        document.querySelectorAll(".archive-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                if (this.disabled) return;
                const queueId   = this.dataset.id;
                const queueName = this.dataset.name;
                showConfirm(
                    'Archive Queue',
                    `Are you sure you want to archive <strong>${queueName}</strong>?<br><br>The queue will be moved to the archive where you can view or restore it later.`,
                    () => archiveQueue(queueId)
                );
            });
        });

        function archiveQueue(queueId) {
            fetch(`/Admin/ArchiveQueueAjax/${queueId}`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "RequestVerificationToken": token }
            })
            .then(res => res.json())
            .then(data => {
                alert(data.message);
                if (data.success) { location.reload(); }
            })
            .catch(err => { console.error("Error:", err); alert("An error occurred. Please try again."); });
        }

        // Search and Filter
        const searchBox        = document.getElementById("searchBox");
        const statusFilter     = document.getElementById("statusFilter");
        const clearFiltersBtn  = document.getElementById("clearFilters");
        const clearFiltersBtnAlt = document.getElementById("clearFiltersBtn");
        const noResults        = document.getElementById("noResults");

        function applyFilters() {
            const searchText = searchBox.value.toLowerCase();
            const status     = statusFilter.value;
            let visibleCount = 0;

            document.querySelectorAll(".queue-card").forEach(card => {
                const matchesSearch = !searchText ||
                    card.dataset.name.includes(searchText) ||
                    card.dataset.code.includes(searchText) ||
                    card.dataset.creator.includes(searchText);
                const matchesStatus = !status || card.dataset.status === status;
                const shouldShow    = matchesSearch && matchesStatus;

                card.style.display = shouldShow ? "block" : "none";
                if (shouldShow) visibleCount++;
            });

            if (noResults) noResults.style.display = visibleCount === 0 ? "block" : "none";
        }

        function clearFilters() {
            searchBox.value    = "";
            statusFilter.value = "";
            applyFilters();
        }

        searchBox.addEventListener("input", applyFilters);
        statusFilter.addEventListener("change", applyFilters);
        clearFiltersBtn.addEventListener("click", clearFilters);
        if (clearFiltersBtnAlt) clearFiltersBtnAlt.addEventListener("click", clearFilters);
    </script>
}

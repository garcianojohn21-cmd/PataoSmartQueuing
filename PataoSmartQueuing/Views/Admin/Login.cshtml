@model PataoSmartQueuing.ViewModels.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    var token = Context.Request.Query["token"].ToString();
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --parakeet-green: #3DDC84;
        --parakeet-dark: #2AB366;
        --parakeet-light: #6FFFB0;
        --parakeet-pale: #E8FFF3;
    }

    .parakeet-card {
        background: linear-gradient(135deg, var(--parakeet-pale) 0%, #ffffff 100%);
        border: 3px solid var(--parakeet-green);
        box-shadow: 0 8px 32px rgba(61, 220, 132, 0.3) !important;
    }

    .parakeet-title {
        color: var(--parakeet-dark);
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(61, 220, 132, 0.1);
    }

    .parakeet-hr {
        border-top: 2px solid var(--parakeet-green);
        opacity: 0.3;
    }

    .input-group-text {
        background-color: var(--parakeet-green);
        color: white;
        border: 1px solid var(--parakeet-dark);
    }

    .form-control {
        border: 1px solid var(--parakeet-green);
    }

        .form-control:focus {
            border-color: var(--parakeet-dark);
            box-shadow: 0 0 0 0.2rem rgba(61, 220, 132, 0.25);
        }

    .btn-parakeet {
        background-color: var(--parakeet-green);
        border-color: var(--parakeet-dark);
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-parakeet:hover {
            background-color: var(--parakeet-dark);
            border-color: var(--parakeet-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(61, 220, 132, 0.4);
        }

    .password-toggle {
        cursor: pointer;
        background-color: var(--parakeet-green);
        color: white;
        border: 1px solid var(--parakeet-dark);
        padding: 0.375rem 0.75rem;
    }

        .password-toggle:hover {
            background-color: var(--parakeet-dark);
        }

    .form-label {
        color: var(--parakeet-dark);
        font-weight: 600;
    }

    .admin-badge {
        background-color: var(--parakeet-green);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
        margin-left: 0.5rem;
    }
</style>

<div class="container mt-5">
    <div class="card parakeet-card shadow p-4 col-md-5 mx-auto rounded-3">
        <h3 class="text-center parakeet-title mb-3">
            Admin Login
            <span class="admin-badge">
                <i class="bi bi-shield-lock-fill"></i> Admin
            </span>
        </h3>
        <hr class="parakeet-hr mb-4" />

        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <input type="hidden" name="token" value="@token" />

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="Enter admin email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <!-- Password with Eye Toggle -->
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <input asp-for="Password" type="password" id="passwordInput" class="form-control" placeholder="Enter password" />
                    <span class="password-toggle" id="togglePassword">
                        <i class="bi bi-eye-fill" id="eyeIcon"></i>
                    </span>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-parakeet w-100 py-2">
                <i class="bi bi-box-arrow-in-right"></i> Login as Admin
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("passwordInput");
        const eyeIcon = document.getElementById("eyeIcon");

        // Password visibility toggle
        togglePassword.addEventListener("click", function () {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);

            if (type === "password") {
                eyeIcon.classList.remove("bi-eye-slash-fill");
                eyeIcon.classList.add("bi-eye-fill");
            } else {
                eyeIcon.classList.remove("bi-eye-fill");
                eyeIcon.classList.add("bi-eye-slash-fill");
            }
        });
    </script>
}
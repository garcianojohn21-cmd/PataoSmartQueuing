@model PataoSmartQueuing.ViewModels.CreateQueueViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Queue";
}

<style>
    :root {
        --navy: #0D1B2A;
        --navy-mid: #1B2E44;
        --navy-light: #243A52;
        --green: #22C55E;
        --green-dark: #16A34A;
        --green-light: #4ADE80;
        --green-pale: #F0FDF4;
        --green-gradient: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
        --navy-gradient: linear-gradient(135deg, #0D1B2A 0%, #1B2E44 100%);
        --white: #FFFFFF;
        --border: rgba(34, 197, 94, 0.25);
        --shadow: 0 8px 32px rgba(13, 27, 42, 0.18);
        --shadow-green: 0 6px 24px rgba(34, 197, 94, 0.25);
    }

    /* ── CARD ── */
    .cq-card {
        background: var(--white);
        border-radius: 22px;
        border: 2px solid var(--border);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .cq-card-header {
        background: var(--navy-gradient);
        padding: 28px 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        position: relative;
        overflow: hidden;
    }

        .cq-card-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--green-gradient);
        }

        .cq-card-header::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(34,197,94,0.12) 0%, transparent 70%);
        }

        .cq-card-header h4 {
            color: var(--white);
            font-weight: 800;
            font-size: 20px;
            letter-spacing: 0.5px;
            margin: 0;
            position: relative;
            z-index: 1;
        }

            .cq-card-header h4 i {
                color: var(--green-light);
            }

    .cq-card-body {
        padding: 36px 32px;
        background: linear-gradient(160deg, #fff 60%, var(--green-pale) 100%);
    }

    /* ── LABELS ── */
    .form-label-cq {
        color: var(--navy);
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .form-label-cq i {
            color: var(--green-dark);
            font-size: 15px;
        }

    /* ── INPUTS ── */
    .form-control-cq {
        border: 2px solid rgba(34,197,94,0.3);
        border-radius: 12px;
        padding: 13px 16px;
        font-size: 14px;
        font-weight: 500;
        color: var(--navy);
        background: var(--white);
        transition: all 0.25s;
        outline: none;
        width: 100%;
        box-sizing: border-box;
        display: block;
    }

        .form-control-cq:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(34,197,94,0.15);
            background: var(--white);
        }

        .form-control-cq::placeholder {
            color: #9CA3AF;
            font-weight: 400;
        }

    /* ── VALIDATION ── */
    .alert-cq-danger {
        background: #FEE2E2;
        border: 2px solid #EF4444;
        border-left: 5px solid #DC2626;
        color: #7F1D1D;
        border-radius: 12px;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13.5px;
        margin-bottom: 20px;
    }

    /* ── BUTTONS ── */
    .btn-cq-create {
        background: var(--green-gradient);
        color: var(--white);
        border: none;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 13.5px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        cursor: pointer;
        transition: all 0.25s;
        box-shadow: var(--shadow-green);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-cq-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(34,197,94,0.4);
            color: var(--white);
        }

        .btn-cq-create:active {
            transform: translateY(0);
        }

    .btn-cq-cancel {
        background: var(--white);
        color: var(--navy-mid);
        border: 2px solid #D1D5DB;
        padding: 13px 28px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 13.5px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        cursor: pointer;
        transition: all 0.25s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-cq-cancel:hover {
            background: #F3F4F6;
            border-color: #9CA3AF;
            color: var(--navy);
            transform: translateY(-2px);
        }

    /* ── MODAL ── */
    .modal-cq .modal-content {
        border: 2px solid var(--border);
        border-radius: 22px;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .modal-cq .modal-header {
        background: var(--navy-gradient);
        border: none;
        padding: 22px 28px;
        position: relative;
    }

        .modal-cq .modal-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--green-gradient);
        }

        .modal-cq .modal-header h5 {
            font-weight: 800;
            font-size: 16px;
            color: var(--white);
            margin: 0;
        }

            .modal-cq .modal-header h5 i {
                color: var(--green-light);
            }

    .modal-cq .modal-body {
        padding: 28px;
        background: linear-gradient(160deg, #fff 60%, var(--green-pale) 100%);
    }

    .modal-cq .modal-footer {
        border: none;
        padding: 20px 28px;
        background: var(--green-pale);
        justify-content: center;
    }

    .modal-label {
        color: var(--navy);
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .modal-label i {
            color: var(--green-dark);
        }

    .input-group-cq {
        display: flex;
        border: 2px solid rgba(34,197,94,0.3);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 20px;
    }

        .input-group-cq input {
            border: none;
            padding: 12px 14px;
            font-weight: 600;
            font-size: 14px;
            color: var(--navy);
            background: var(--white);
            flex: 1;
            outline: none;
        }

        .input-group-cq .copy-btn {
            border: none;
            border-left: 2px solid rgba(34,197,94,0.3);
            background: var(--white);
            color: var(--green-dark);
            font-weight: 700;
            font-size: 13px;
            padding: 12px 16px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .input-group-cq .copy-btn:hover {
                background: var(--green-gradient);
                color: var(--white);
            }

    .modal-note {
        background: var(--navy);
        border-radius: 12px;
        padding: 14px 16px;
        color: rgba(255,255,255,0.8);
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .modal-note i {
            color: var(--green-light);
            flex-shrink: 0;
        }

    .success-icon {
        width: 80px;
        height: 80px;
        background: var(--green-gradient);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--white);
        font-size: 2.2rem;
        margin: 0 auto 24px;
        box-shadow: var(--shadow-green);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100%

    {
        transform: scale(1);
        box-shadow: 0 6px 20px rgba(34,197,94,0.3);
    }

    50% {
        transform: scale(1.06);
        box-shadow: 0 8px 28px rgba(34,197,94,0.5);
    }

    }

    @@media (max-width: 768px) {
        .cq-card-body

    {
        padding: 22px 18px;
    }

    .cq-card-header {
        padding: 18px 20px;
    }

    .btn-cq-create, .btn-cq-cancel {
        width: 100%;
        justify-content: center;
    }

    }
</style>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="cq-card">

                <div class="cq-card-header">
                    <h4>
                        <i class="bi bi-plus-circle-fill me-2"></i>Create a New Queue
                    </h4>
                </div>

                <div class="cq-card-body">

                    <div id="validationSummary" class="alert-cq-danger d-none"></div>
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <form id="createQueueForm" asp-action="CreateQueue" asp-controller="Admin" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label asp-for="QueueName" class="form-label-cq">
                                <i class="bi bi-tag-fill"></i> Queue Name
                            </label>
                            <input asp-for="QueueName" class="form-control-cq" placeholder="Enter queue name (must be unique)" />
                            <span asp-validation-for="QueueName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label-cq">
                                <i class="bi bi-card-text"></i> Description
                            </label>
                            <textarea asp-for="Description" class="form-control-cq" rows="4" placeholder="Enter queue description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="MaxStudents" class="form-label-cq">
                                <i class="bi bi-people-fill"></i> Maximum Students
                            </label>
                            <input asp-for="MaxStudents" type="number" class="form-control-cq" placeholder="Enter maximum students allowed" />
                            <span asp-validation-for="MaxStudents" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between flex-wrap gap-2">
                            <a asp-controller="Admin" asp-action="Dashboard" class="btn-cq-cancel">
                                <i class="bi bi-arrow-left-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn-cq-create">
                                <i class="bi bi-plus-circle"></i> Create Queue
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade modal-cq" id="QueueCodeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-check-circle-fill me-2"></i>Queue Created Successfully!
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="success-icon">
                    <i class="bi bi-check-lg"></i>
                </div>

                <div class="mb-4">
                    <p class="modal-label"><i class="bi bi-tag-fill"></i> Queue Name</p>
                    <p class="fw-semibold ps-1 mb-0" id="modalQueueName" style="color: var(--navy);"></p>
                </div>

                <div class="mb-4">
                    <p class="modal-label"><i class="bi bi-key-fill"></i> Queue Code</p>
                    <div class="input-group-cq">
                        <input type="text" readonly id="modalQueueCode" />
                        <button class="copy-btn" onclick="copyToClipboard('modalQueueCode', this)">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                </div>

                <div class="mb-4">
                    <p class="modal-label"><i class="bi bi-link-45deg"></i> Join Link</p>
                    <div class="input-group-cq">
                        <input type="text" readonly id="modalJoinLink" />
                        <button class="copy-btn" onclick="copyToClipboard('modalJoinLink', this)">
                            <i class="fas fa-link"></i> Copy
                        </button>
                    </div>
                </div>

                <div class="modal-note">
                    <i class="bi bi-info-circle-fill"></i>
                    Share the code or link with students via group chats or messengers.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cq-create" onclick="redirectToManageQueues()">
                    <i class="bi bi-arrow-right-circle"></i> Go to Manage Queues
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $("#createQueueForm").submit(function (e) {
            e.preventDefault();
            const form = $(this);

            $.ajax({
                url: form.attr("action"),
                method: "POST",
                data: form.serialize(),
                dataType: "json",
                success: function (res) {
                    if (res.success) {
                        $("#validationSummary").addClass("d-none").empty();
                        $("#modalQueueName").text(res.queueName);
                        $("#modalQueueCode").val(res.queueCode);
                        $("#modalJoinLink").val(res.joinLink);

                        const modalElement = document.getElementById("QueueCodeModal");
                        const modal = new bootstrap.Modal(modalElement);
                        modal.show();

                        modalElement.addEventListener("hidden.bs.modal", function () {
                            redirectToManageQueues();
                        });
                    } else {
                        $("#validationSummary")
                            .removeClass("d-none")
                            .html(res.errors.join("<br>"));
                    }
                },
                error: function () {
                    $("#validationSummary")
                        .removeClass("d-none")
                        .text("An unexpected error occurred while creating the queue.");
                }
            });
        });

        function copyToClipboard(inputId, button) {
            const input = document.getElementById(inputId);
            input.select();
            navigator.clipboard.writeText(input.value);

            const original = button.innerHTML;
            button.innerHTML = "<i class='fas fa-check'></i> Copied!";
            button.style.background = "var(--green-gradient)";
            button.style.color = "white";

            setTimeout(() => {
                button.innerHTML = original;
                button.style.background = "";
                button.style.color = "";
            }, 2000);
        }

        function redirectToManageQueues() {
            window.location.href = "/Admin/ManageQueues";
        }
    </script>
}

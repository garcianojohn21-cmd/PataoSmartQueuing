@model IEnumerable<PataoSmartQueuing.Models.ViewModels.QueueStudentViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Unserved Students Management";
}

@Html.AntiForgeryToken()

<style>
    :root {
        --parakeet-green: #22C55E;
        --parakeet-dark: #16A34A;
        --parakeet-light: #4ADE80;
        --parakeet-pale: #F0FDF4;
        --parakeet-glow: rgba(34, 197, 94, 0.25);
        --parakeet-navy: #1E293B;
        --parakeet-border: rgba(34, 197, 94, 0.3);
        --parakeet-gradient: linear-gradient(135deg, #22C55E, #16A34A);
        --parakeet-shadow: 0 4px 16px rgba(34, 197, 94, 0.2);
        --parakeet-shadow-sm: 0 2px 8px rgba(34, 197, 94, 0.12);
    }

    /* ── HEADER ── */
    .header-section {
        background: var(--parakeet-gradient);
        border-radius: 14px;
        padding: 20px 24px;
        margin-bottom: 24px;
        box-shadow: var(--parakeet-shadow);
    }

    .page-title {
        color: white;
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 4px 0;
    }

    .page-subtitle {
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.95rem;
        margin: 0;
    }

    .btn-header-solid {
        background: white;
        color: var(--parakeet-dark);
        border: none;
        padding: 9px 18px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.4px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.25s;
    }

        .btn-header-solid:hover {
            background: var(--parakeet-pale);
            color: var(--parakeet-dark);
            transform: translateY(-2px);
        }

    .btn-header-outline {
        background: rgba(255, 255, 255, 0.15);
        color: white;
        border: 1.5px solid rgba(255, 255, 255, 0.5);
        padding: 9px 18px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.4px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.25s;
    }

        .btn-header-outline:hover {
            background: white;
            color: var(--parakeet-dark);
            transform: translateY(-2px);
        }

    /* ── CONTROL PANEL ── */
    .control-panel {
        background: white;
        border-radius: 14px;
        padding: 20px 24px;
        margin-bottom: 24px;
        box-shadow: var(--parakeet-shadow-sm);
        border: 1.5px solid var(--parakeet-border);
    }

    .control-label {
        font-weight: 700;
        color: var(--parakeet-navy);
        margin-bottom: 8px;
        display: block;
        font-size: 12px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .form-select-custom, .form-control-custom {
        border: 1.5px solid var(--parakeet-border);
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 14px;
        color: var(--parakeet-navy);
        width: 100%;
        transition: all 0.25s;
        box-shadow: var(--parakeet-shadow-sm);
        background: white;
    }

        .form-select-custom:focus, .form-control-custom:focus {
            border-color: var(--parakeet-green);
            box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15);
            outline: none;
        }

    .btn-refresh {
        background: var(--parakeet-gradient);
        color: white;
        border: none;
        padding: 11px 18px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 13px;
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.25s;
        box-shadow: var(--parakeet-shadow-sm);
    }

        .btn-refresh:hover {
            transform: translateY(-2px);
            box-shadow: var(--parakeet-shadow);
        }

    /* ── STAT CARDS ── */
    .stat-card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: var(--parakeet-shadow-sm);
        border: 1.5px solid var(--parakeet-border);
        border-left: 4px solid var(--parakeet-green);
        transition: all 0.25s;
        height: 100%;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--parakeet-shadow);
        }

    .stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 10px;
        background: var(--parakeet-pale);
        color: var(--parakeet-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 12px;
    }

    .stat-value {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--parakeet-navy);
        margin: 0;
    }

    .stat-label {
        font-size: 0.85rem;
        color: #64748B;
        margin: 4px 0 0 0;
        font-weight: 500;
    }

    /* ── STUDENT CARDS ── */
    .student-card {
        background: white;
        border-radius: 16px;
        padding: 22px;
        box-shadow: var(--parakeet-shadow-sm);
        border: 1.5px solid var(--parakeet-border);
        transition: all 0.25s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .student-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--parakeet-shadow);
            border-color: var(--parakeet-green);
        }

    .card-badge {
        background: #FEF3C7;
        color: #92400E;
        border: 1.5px solid #F59E0B;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 14px;
    }

    .student-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 14px;
    }

    .student-avatar {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        object-fit: cover;
        border: 2.5px solid var(--parakeet-border);
        flex-shrink: 0;
    }

    .student-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--parakeet-navy);
        margin: 0 0 5px 0;
    }

    .queue-badge {
        background: var(--parakeet-pale);
        color: var(--parakeet-dark);
        padding: 3px 10px;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 700;
        border: 1.5px solid var(--parakeet-border);
    }

    .detail-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #64748B;
        font-size: 13px;
        margin-bottom: 6px;
    }

        .detail-item i {
            color: var(--parakeet-green);
            flex-shrink: 0;
        }

    /* ── PIN SECTION ── */
    .pin-section {
        margin-bottom: 14px;
    }

    .pin-label {
        font-weight: 700;
        color: var(--parakeet-navy);
        margin-bottom: 8px;
        display: block;
        font-size: 12px;
        letter-spacing: 0.4px;
        text-transform: uppercase;
    }

    /* unified wrapper — border lives here, not on the input */
    .pin-input-wrapper {
        display: flex;
        align-items: center;
        border: 1.5px solid var(--parakeet-border);
        border-radius: 10px;
        overflow: hidden;
        background: white;
        box-shadow: var(--parakeet-shadow-sm);
        transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
    }

        .pin-input-wrapper:focus-within {
            border-color: var(--parakeet-green);
            box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15);
        }

        .pin-input-wrapper.is-valid {
            border-color: #22C55E;
            background: #F0FDF4;
        }

        .pin-input-wrapper.is-invalid {
            border-color: #EF4444;
            background: #FEF2F2;
        }

    .pin-input {
        flex: 1;
        border: none;
        outline: none;
        padding: 11px 14px;
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        letter-spacing: 0.25em;
        background: transparent;
        color: var(--parakeet-navy);
        box-shadow: none !important;
        min-width: 0;
    }

        .pin-input:focus {
            border: none;
            outline: none;
            box-shadow: none;
        }

    .pin-toggle {
        flex-shrink: 0;
        width: 42px;
        height: 100%;
        min-height: 44px;
        border: none;
        border-left: 1.5px solid var(--parakeet-border);
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--parakeet-dark);
        transition: background 0.2s, color 0.2s;
    }

        .pin-toggle:hover {
            background: var(--parakeet-pale);
            color: var(--parakeet-green);
        }

    .pin-feedback {
        margin-top: 6px;
        font-size: 12px;
        min-height: 18px;
        font-weight: 600;
    }

        .pin-feedback.valid {
            color: #16A34A;
        }

        .pin-feedback.invalid {
            color: #DC2626;
        }

    /* ── COMPLETE BUTTON ── */
    .btn-complete {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: none;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.4px;
        cursor: pointer;
        transition: all 0.25s;
        margin-top: auto;
    }

        .btn-complete:disabled {
            background: #F1F5F9;
            color: #94A3B8;
            cursor: not-allowed;
        }

        .btn-complete:not(:disabled) {
            background: var(--parakeet-gradient);
            color: white;
            box-shadow: var(--parakeet-shadow-sm);
        }

            .btn-complete:not(:disabled):hover {
                transform: translateY(-2px);
                box-shadow: var(--parakeet-shadow);
            }

    /* ── EMPTY STATES ── */
    .empty-state {
        text-align: center;
        padding: 60px 24px;
        background: white;
        border-radius: 16px;
        border: 1.5px solid var(--parakeet-border);
        box-shadow: var(--parakeet-shadow-sm);
    }

    .empty-icon {
        font-size: 3.5rem;
        color: #CBD5E1;
        margin-bottom: 14px;
    }

    .success-state .empty-icon {
        color: var(--parakeet-green);
    }

    .empty-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--parakeet-navy);
        margin-bottom: 8px;
    }

    .empty-text {
        color: #64748B;
        font-size: 14px;
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 768px) {
        .page-title {
            font-size: 1.4rem;
        }

        .btn-group-custom {
            width: 100%;
        }

        .student-card {
            padding: 16px;
        }

        .empty-state {
            padding: 40px 16px;
        }
    }
</style>

<div class="container-fluid px-4 py-4">

    <!-- Header -->
    <div class="header-section">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="page-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Unserved Students
                </h1>
                <p class="page-subtitle">Complete pending services with PIN verification</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
               
                <a asp-action="ManageQueues" class="btn-header-outline">
                    <i class="bi bi-arrow-left me-2"></i> Back to Queues
                </a>
            </div>
        </div>
    </div>

    <!-- Control Panel -->
    <div class="control-panel">
        <div class="row g-3">
            <div class="col-lg-5">
                <label class="control-label">
                    <i class="bi bi-list-ul me-1"></i> Select Queue
                </label>
                <select id="queueSelector" class="form-select-custom">
                    <option value="">-- Choose a Queue --</option>
                    @if (ViewBag.Queues != null)
                    {
                        foreach (var queue in ViewBag.Queues)
                        {
                            var selected = queue.QueueID == ViewBag.QueueId ? "selected" : "";
                            var statusBadge = queue.IsActive ? "🟢 Active" : queue.IsDone ? "✅ Done" : "⏸️ Inactive";
                            <option value="@queue.QueueID" selected>
                                @queue.QueueName (@statusBadge)
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-lg-5">
                <label class="control-label">
                    <i class="bi bi-search me-1"></i> Search Students
                </label>
                <input type="text" id="searchBox" class="form-control-custom"
                       placeholder="🔍 Search by name, queue number, or email...">
            </div>
            <div class="col-lg-2">
                <label class="control-label" style="opacity:0;">.</label>
                <button id="refreshBtn" class="btn-refresh">
                    <i class="bi bi-arrow-clockwise me-2"></i> Refresh
                </button>
            </div>
        </div>
    </div>

    <!-- Stats -->
    @if (ViewBag.QueueId != 0)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon"><i class="bi bi-inbox-fill"></i></div>
                    <h3 class="stat-value">@ViewBag.QueueName</h3>
                    <p class="stat-label">Current Queue</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon"><i class="bi bi-exclamation-circle-fill"></i></div>
                    <h3 class="stat-value" id="totalUnserved">@ViewBag.TotalUnserved</h3>
                    <p class="stat-label">Total Unserved</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="stat-icon"><i class="bi bi-eye-fill"></i></div>
                    <h3 class="stat-value" id="visibleCount">@Model.Count()</h3>
                    <p class="stat-label">Currently Showing</p>
                </div>
            </div>
        </div>
    }

    <!-- Students Grid -->
    @if (ViewBag.QueueId == 0)
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-inbox"></i></div>
            <h3 class="empty-title">No Queue Selected</h3>
            <p class="empty-text">Please select a queue from the dropdown above to view unserved students.</p>
        </div>
    }
    else if (!Model.Any())
    {
        <div class="empty-state success-state">
            <div class="empty-icon"><i class="bi bi-check-circle-fill"></i></div>
            <h3 class="empty-title">All Students Served! 🎉</h3>
            <p class="empty-text">There are no unserved students in this queue. Outstanding work!</p>
        </div>
    }
    else
    {
        <div id="unservedContainer" class="row g-4">
            @foreach (var s in Model)
            {
                var profileSrc = string.IsNullOrEmpty(s.ProfilePhoto)
                ? "/Images/ProfilePic.jfif"
                : s.ProfilePhoto;

                <div class="col-lg-4 col-md-6 student-card-wrapper"
                     data-id="@s.QueueStudentID"
                     data-name="@s.StudentName.ToLower()"
                     data-email="@s.Email.ToLower()"
                     data-queue="@s.QueueNumber">
                    <div class="student-card">
                        <div class="card-badge">
                            <i class="bi bi-exclamation-circle-fill me-1"></i> Unserved
                        </div>

                        <div class="student-header">
                            <img src="@profileSrc"
                                 alt="Profile"
                                 class="student-avatar"
                                 onerror="this.src='/Images/ProfilePic.jfif'">
                            <div>
                                <h5 class="student-name">@s.StudentName</h5>
                                <span class="queue-badge">
                                    <i class="bi bi-hash"></i>@s.QueueNumber
                                </span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="detail-item">
                                <i class="bi bi-envelope-fill"></i>
                                <span>@s.Email</span>
                            </div>
                        </div>

                        <!-- PIN -->
                        <div class="pin-section">
                            <label class="pin-label">
                                <i class="bi bi-shield-lock-fill me-1"></i> Student's PIN Code
                            </label>
                            <div class="pin-input-wrapper">
                                <input type="password"
                                       class="pin-input"
                                       placeholder="Enter 6-digit PIN"
                                       maxlength="6"
                                       data-id="@s.QueueStudentID"
                                       autocomplete="off" />
                                <button class="pin-toggle toggle-pin" type="button">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <div class="pin-feedback"></div>
                        </div>

                        <!-- Action -->
                        <button class="btn-complete complete-btn"
                                data-id="@s.QueueStudentID"
                                data-name="@s.StudentName"
                                disabled>
                            <i class="bi bi-check-circle-fill me-2"></i> Complete Service
                        </button>
                    </div>
                </div>
            }
        </div>
    }

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        console.log('🚀 Unserved List Initializing...');

        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        function showToast(message, type = 'success') {
            const icons = {
                success: 'check-circle-fill',
                danger:  'x-circle-fill',
                warning: 'exclamation-triangle-fill',
                info:    'info-circle-fill'
            };
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} position-fixed top-0 start-50 translate-middle-x mt-3 shadow-lg`;
            toast.style.cssText = 'z-index:9999;min-width:350px;border-radius:12px;';
            toast.innerHTML = `
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-${icons[type] || icons.info} fs-5"></i>
                    <div class="flex-grow-1">${message}</div>
                </div>`;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.transition = 'all 0.3s ease';
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        async function sendRequest(url, data) {
            const formData = new FormData();
            for (const [key, value] of Object.entries(data)) formData.append(key, value);
            formData.append('__RequestVerificationToken', getToken());
            const response = await fetch(url, { method: 'POST', body: formData, credentials: 'same-origin' });
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            return await response.json();
        }

        function attachQueueSelector() {
            const selector = document.getElementById('queueSelector');
            if (!selector) return;
            selector.addEventListener('change', function () {
                if (this.value) window.location.href = `/Admin/UnservedList?queueId=${this.value}`;
            });
        }

        function attachSearchFilter() {
            const searchBox = document.getElementById('searchBox');
            if (!searchBox) return;
            searchBox.addEventListener('input', function () {
                const term = this.value.toLowerCase();
                let count = 0;
                document.querySelectorAll('.student-card-wrapper').forEach(card => {
                    const match = card.dataset.name.includes(term) ||
                                  card.dataset.email.includes(term) ||
                                  card.dataset.queue.includes(term);
                    card.style.display = match ? '' : 'none';
                    if (match) count++;
                });
                const el = document.getElementById('visibleCount');
                if (el) el.textContent = count;
            });
        }

        function attachPinInputs() {
            document.querySelectorAll('.pin-input').forEach(input => {
                let timeout;

                input.addEventListener('keypress', e => {
                    if (!/\d/.test(e.key) && e.key !== 'Enter') e.preventDefault();
                });

                input.addEventListener('input', async function () {
                    const pin = this.value.trim();
                    const id  = this.dataset.id;
                    const card = this.closest('.student-card');
                    const wrapper = this.closest('.pin-input-wrapper');
                    const feedback = card.querySelector('.pin-feedback');
                    const completeBtn = card.querySelector('.complete-btn');

                    wrapper.classList.remove('is-valid', 'is-invalid');
                    feedback.className = 'pin-feedback';
                    feedback.textContent = '';
                    if (completeBtn) completeBtn.disabled = true;
                    if (pin.length !== 6) return;

                    clearTimeout(timeout);
                    feedback.textContent = '🔍 Validating PIN...';
                    feedback.style.color = '#64748B';

                    timeout = setTimeout(async () => {
                        try {
                            const result = await sendRequest('/Admin/ValidateUnservedPin', { id, pinCode: pin });
                            if (result.success) {
                                wrapper.classList.add('is-valid');
                                feedback.textContent = '✅ ' + result.message;
                                feedback.classList.add('valid');
                                if (completeBtn) completeBtn.disabled = false;
                            } else {
                                wrapper.classList.add('is-invalid');
                                feedback.textContent = '❌ ' + result.message;
                                feedback.classList.add('invalid');
                            }
                        } catch (err) {
                            wrapper.classList.add('is-invalid');
                            feedback.textContent = '❌ Error validating PIN';
                            feedback.classList.add('invalid');
                        }
                    }, 500);
                });
            });

            document.querySelectorAll('.toggle-pin').forEach(btn => {
                btn.addEventListener('click', function () {
                    const input = this.parentElement.querySelector('.pin-input');
                    const icon  = this.querySelector('i');
                    const isPass = input.type === 'password';
                    input.type = isPass ? 'text' : 'password';
                    icon.classList.toggle('bi-eye', !isPass);
                    icon.classList.toggle('bi-eye-slash', isPass);
                });
            });
        }

        function attachCompleteButtons() {
            document.querySelectorAll('.complete-btn').forEach(btn => {
                const id   = btn.dataset.id;
                const name = btn.dataset.name;
                const newBtn = btn.cloneNode(true);
                btn.parentNode.replaceChild(newBtn, btn);

                newBtn.onclick = async function (e) {
                    e.preventDefault();
                    const card = this.closest('.student-card');
                    const pinInput = card.querySelector('.pin-input');
                    const pin = pinInput?.value.trim();

                    if (!pin || pin.length !== 6) {
                        alert('Please enter a valid 6-digit PIN code.');
                        pinInput?.focus();
                        return;
                    }
                    if (!confirm(`Complete service for ${name}?\n\nThis will mark them as Done and send a confirmation email.`)) return;

                    this.disabled = true;
                    const original = this.innerHTML;
                    this.innerHTML = '<i class="bi bi-hourglass-split me-2"></i> Processing...';

                    try {
                        const result = await sendRequest('/Admin/CompleteUnservedStudent', { id, pinCode: pin });
                        if (result.success) {
                            showToast(result.message, 'success');
                            setTimeout(() => location.reload(), 1500);
                        } else {
                            showToast(result.message || 'Failed to complete service', 'danger');
                            this.disabled = false;
                            this.innerHTML = original;
                        }
                    } catch (err) {
                        showToast('Error: ' + err.message, 'danger');
                        this.disabled = false;
                        this.innerHTML = original;
                    }
                };
            });
        }

        async function initializeSignalR() {
            try {
                if (typeof signalR === 'undefined') {
                    await new Promise(resolve => {
                        const check = setInterval(() => {
                            if (typeof signalR !== 'undefined') { clearInterval(check); resolve(); }
                        }, 100);
                    });
                }
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();
                connection.on("RefreshQueue", () => {
                    showToast('Queue updated!', 'info');
                    setTimeout(() => location.reload(), 1000);
                });
                await connection.start();
                console.log("✅ SignalR Connected");
            } catch (err) {
                console.error("❌ SignalR Error:", err);
            }
        }

        function initializeAll() {
            attachQueueSelector();
            attachSearchFilter();
            attachPinInputs();
            attachCompleteButtons();
            initializeSignalR();
            const refreshBtn = document.getElementById('refreshBtn');
            if (refreshBtn) refreshBtn.addEventListener('click', () => location.reload());
            console.log('✅ All handlers attached');
        }

        document.readyState === 'loading'
            ? document.addEventListener('DOMContentLoaded', initializeAll)
            : initializeAll();
    </script>
}

@model PataoSmartQueuing.Models.Queue
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Queue";
}

<style>
    :root {
        --navy: #0D1B2A;
        --navy-mid: #1B2E44;
        --navy-light: #243A52;
        --green: #22C55E;
        --green-dark: #16A34A;
        --green-light: #4ADE80;
        --green-pale: #F0FDF4;
        --green-gradient: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
        --navy-gradient: linear-gradient(135deg, #0D1B2A 0%, #1B2E44 100%);
        --white: #FFFFFF;
        --border: rgba(34, 197, 94, 0.25);
        --shadow: 0 8px 32px rgba(13, 27, 42, 0.18);
        --shadow-green: 0 6px 24px rgba(34, 197, 94, 0.25);
    }

    /* ── CARD ── */
    .cq-card {
        background: var(--white);
        border-radius: 22px;
        border: 2px solid var(--border);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .cq-card-header {
        background: var(--navy-gradient);
        padding: 28px 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        position: relative;
        overflow: hidden;
    }

        .cq-card-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--green-gradient);
        }

        .cq-card-header::before {
            content: '';
            position: absolute;
            top: -60px;
            right: -60px;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(34,197,94,0.12) 0%, transparent 70%);
        }

        .cq-card-header h4 {
            color: var(--white);
            font-weight: 800;
            font-size: 20px;
            letter-spacing: 0.5px;
            margin: 0;
            position: relative;
            z-index: 1;
        }

            .cq-card-header h4 i {
                color: var(--green-light);
            }

    .cq-card-body {
        padding: 36px 32px;
        background: linear-gradient(160deg, #fff 60%, var(--green-pale) 100%);
    }

    /* ── LABELS ── */
    .form-label-cq {
        color: var(--navy);
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .form-label-cq i {
            color: var(--green-dark);
            font-size: 15px;
        }

    /* ── INPUTS ── */
    .form-control-cq {
        border: 2px solid rgba(34,197,94,0.3);
        border-radius: 12px;
        padding: 13px 16px;
        font-size: 14px;
        font-weight: 500;
        color: var(--navy);
        background: var(--white);
        transition: all 0.25s;
        outline: none;
        width: 100%;
        box-sizing: border-box;
        display: block;
    }

        .form-control-cq:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(34,197,94,0.15);
            background: var(--white);
        }

        .form-control-cq::placeholder {
            color: #9CA3AF;
            font-weight: 400;
        }

        .form-control-cq[readonly] {
            background: #F9FAFB;
            color: #6B7280;
            cursor: default;
        }

    textarea.form-control-cq {
        resize: vertical;
    }

    /* ── FORM HINT TEXT ── */
    .form-hint {
        font-size: 12px;
        color: #6B7280;
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .form-hint i {
            color: var(--green-dark);
        }

    /* ── WARNING ALERT ── */
    .alert-cq-warning {
        background: #FFFBEB;
        border: 2px solid #F59E0B;
        border-left: 5px solid #D97706;
        color: #78350F;
        border-radius: 12px;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13.5px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* ── INFO PANEL ── */
    .info-panel {
        background: var(--navy);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
    }

        .info-panel::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(34,197,94,0.15) 0%, transparent 70%);
        }

    .info-panel-title {
        color: var(--green-light);
        font-weight: 800;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        position: relative;
        z-index: 1;
    }

    .info-panel-label {
        color: rgba(255,255,255,0.5);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }

    .info-panel .form-control-cq[readonly] {
        background: rgba(255,255,255,0.07);
        border-color: rgba(34,197,94,0.2);
        color: rgba(255,255,255,0.85);
    }

    /* ── INPUT GROUP ── */
    .input-group-cq {
        display: flex;
        border: 2px solid rgba(34,197,94,0.3);
        border-radius: 12px;
        overflow: hidden;
    }

        .input-group-cq input {
            border: none;
            padding: 12px 14px;
            font-weight: 500;
            font-size: 14px;
            color: var(--navy);
            background: var(--white);
            flex: 1;
            outline: none;
        }

    .info-panel .input-group-cq {
        border-color: rgba(34,197,94,0.2);
    }

        .info-panel .input-group-cq input {
            background: rgba(255,255,255,0.07);
            color: rgba(255,255,255,0.85);
        }

    .input-group-cq .copy-btn {
        border: none;
        border-left: 2px solid rgba(34,197,94,0.3);
        background: transparent;
        color: var(--green-light);
        font-weight: 700;
        font-size: 13px;
        padding: 12px 16px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

        .input-group-cq .copy-btn:hover {
            background: var(--green-gradient);
            color: var(--white);
        }

    /* ── STATUS BADGE ── */
    .badge-cq {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .badge-cq-active {
        background: rgba(34,197,94,0.15);
        color: var(--green-light);
        border: 1px solid rgba(34,197,94,0.3);
    }

    .badge-cq-pending {
        background: rgba(245,158,11,0.15);
        color: #FCD34D;
        border: 1px solid rgba(245,158,11,0.3);
    }

    .badge-cq-done {
        background: rgba(156,163,175,0.15);
        color: #D1D5DB;
        border: 1px solid rgba(156,163,175,0.3);
    }

    /* ── STATS CARD ── */
    .stats-card {
        background: var(--white);
        border-radius: 22px;
        border: 2px solid var(--border);
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-top: 28px;
    }

    .stats-card-header {
        background: var(--navy-gradient);
        padding: 20px 28px;
        display: flex;
        align-items: center;
        gap: 10px;
        position: relative;
        overflow: hidden;
    }

        .stats-card-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--green-gradient);
        }

        .stats-card-header h5 {
            color: var(--white);
            font-weight: 800;
            font-size: 16px;
            margin: 0;
        }

            .stats-card-header h5 i {
                color: var(--green-light);
            }

    .stats-card-body {
        padding: 28px;
        background: linear-gradient(160deg, #fff 60%, var(--green-pale) 100%);
    }

    .stat-tile {
        background: var(--white);
        border: 2px solid var(--border);
        border-radius: 16px;
        padding: 22px 16px;
        text-align: center;
        transition: all 0.25s;
    }

        .stat-tile:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-green);
            border-color: var(--green);
        }

        .stat-tile i {
            font-size: 2rem;
            display: block;
            margin-bottom: 10px;
        }

        .stat-tile .stat-num {
            font-size: 28px;
            font-weight: 800;
            color: var(--navy);
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-tile .stat-label {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6B7280;
        }

    /* ── BUTTONS ── */
    .btn-cq-save {
        background: var(--green-gradient);
        color: var(--white);
        border: none;
        padding: 14px 28px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 13.5px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        cursor: pointer;
        transition: all 0.25s;
        box-shadow: var(--shadow-green);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-cq-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(34,197,94,0.4);
            color: var(--white);
        }

        .btn-cq-save:active {
            transform: translateY(0);
        }

    .btn-cq-cancel {
        background: var(--white);
        color: var(--navy-mid);
        border: 2px solid #D1D5DB;
        padding: 13px 28px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 13.5px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        cursor: pointer;
        transition: all 0.25s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

        .btn-cq-cancel:hover {
            background: #F3F4F6;
            border-color: #9CA3AF;
            color: var(--navy);
            transform: translateY(-2px);
        }

    /* ── VALIDATION ── */
    .alert-cq-danger {
        background: #FEE2E2;
        border: 2px solid #EF4444;
        border-left: 5px solid #DC2626;
        color: #7F1D1D;
        border-radius: 12px;
        padding: 14px 16px;
        font-weight: 600;
        font-size: 13.5px;
        margin-bottom: 20px;
    }

    @@media (max-width: 768px) {
        .cq-card-body {
            padding: 22px 18px;
        }

        .cq-card-header {
            padding: 18px 20px;
        }

        .btn-cq-save, .btn-cq-cancel {
            width: 100%;
            justify-content: center;
        }

        .stats-card-body {
            padding: 18px;
        }
    }
</style>

<div class="container my-5" style="max-width: 900px;">
    <div class="row justify-content-center">
        <div class="col-12">

            <div class="cq-card">

                <div class="cq-card-header">
                    <h4>
                        <i class="bi bi-pencil-square me-2"></i>Edit Queue
                    </h4>
                </div>

                <div class="cq-card-body">

                    @if (Model.IsActive)
                    {
                        <div class="alert-cq-warning">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                            <span><strong>Warning:</strong> This queue is currently active. Changes may affect ongoing operations.</span>
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert-cq-danger d-none"></div>

                    <form asp-action="EditQueue" method="post" id="editQueueForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="QueueID" />
                        <input type="hidden" asp-for="QueueCode" />
                        <input type="hidden" asp-for="CreatedByAdminID" />
                        <input type="hidden" asp-for="DateCreated" />
                        <input type="hidden" asp-for="IsActive" />
                        <input type="hidden" asp-for="IsDone" />

                        <!-- Queue Name -->
                        <div class="mb-4">
                            <label asp-for="QueueName" class="form-label-cq">
                                <i class="bi bi-tag-fill"></i> Queue Name
                            </label>
                            <input asp-for="QueueName"
                                   class="form-control-cq"
                                   placeholder="e.g., Registration for Grade 11"
                                   required />
                            <span asp-validation-for="QueueName" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            <label asp-for="Description" class="form-label-cq">
                                <i class="bi bi-card-text"></i> Description
                            </label>
                            <textarea asp-for="Description"
                                      class="form-control-cq"
                                      rows="4"
                                      placeholder="Provide details about this queue..."
                                      required></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Max Students -->
                        <div class="mb-4">
                            <label asp-for="MaxStudents" class="form-label-cq">
                                <i class="bi bi-people-fill"></i> Maximum Students
                            </label>
                            <input asp-for="MaxStudents"
                                   type="number"
                                   class="form-control-cq"
                                   min="1"
                                   max="1000"
                                   required />
                            <p class="form-hint">
                                <i class="bi bi-info-circle-fill"></i>
                                Currently in queue: <strong>@(Model.QueueStudents?.Count(qs => qs.Status != "Done") ?? 0)</strong> student(s)
                            </p>
                            <span asp-validation-for="MaxStudents" class="text-danger small"></span>
                        </div>

                        <!-- Serving Batch Size -->
                        <div class="mb-5">
                            <label asp-for="ServingBatchSize" class="form-label-cq">
                                <i class="bi bi-person-check-fill"></i> Serving Batch Size
                            </label>
                            <input asp-for="ServingBatchSize"
                                   type="number"
                                   class="form-control-cq"
                                   min="1"
                                   max="10"
                                   value="@(Model.ServingBatchSize == 0 ? 1 : Model.ServingBatchSize)" />
                            <p class="form-hint">
                                <i class="bi bi-info-circle-fill"></i>
                                Number of students that can be served simultaneously (1–10)
                            </p>
                            <span asp-validation-for="ServingBatchSize" class="text-danger small"></span>
                        </div>

                        <!-- Queue Information Panel -->
                        <div class="info-panel mb-5">
                            <p class="info-panel-title">
                                <i class="bi bi-info-circle-fill"></i> Queue Information
                            </p>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <p class="info-panel-label">Queue Code</p>
                                    <div class="input-group-cq">
                                        <input type="text" value="@Model.QueueCode" readonly />
                                        <button class="copy-btn" type="button" data-copy="@Model.QueueCode">
                                            <i class="bi bi-clipboard"></i> Copy
                                        </button>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <p class="info-panel-label">Status</p>
                                    <div class="pt-1">
                                        @if (Model.IsDone)
                                        {
                                            <span class="badge-cq badge-cq-done"><i class="bi bi-check-circle-fill"></i> Done</span>
                                        }
                                        else if (Model.IsActive)
                                        {
                                            <span class="badge-cq badge-cq-active"><i class="bi bi-circle-fill" style="font-size:8px;"></i> Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge-cq badge-cq-pending"><i class="bi bi-clock-fill"></i> Pending</span>
                                        }
                                    </div>
                                </div>

                                <div class="col-12">
                                    <p class="info-panel-label">Join Link</p>
                                    @{
                                        var joinLink = $"{Context.Request.Scheme}://{Context.Request.Host}/Student/JoinQueue?code={Model.QueueCode}";
                                    }
                                    <div class="input-group-cq">
                                        <input type="text" value="@joinLink" readonly />
                                        <button class="copy-btn" type="button" data-copy="@joinLink">
                                            <i class="bi bi-link-45deg"></i> Copy
                                        </button>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <p class="info-panel-label">Created On</p>
                                    <input type="text" class="form-control-cq" value="@Model.DateCreated.ToString("MMMM dd, yyyy hh:mm tt")" readonly />
                                </div>

                                <div class="col-md-6">
                                    <p class="info-panel-label">Created By</p>
                                    <input type="text" class="form-control-cq" value="@Model.CreatedByAdmin?.FirstName @Model.CreatedByAdmin?.LastName" readonly />
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between flex-wrap gap-2">
                            <a asp-action="ManageQueues" class="btn-cq-cancel">
                                <i class="bi bi-arrow-left-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn-cq-save">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            <!-- Queue Statistics -->
            @if (Model.QueueStudents != null && Model.QueueStudents.Any())
            {
                <div class="stats-card">
                    <div class="stats-card-header">
                        <h5><i class="bi bi-graph-up me-2"></i>Queue Statistics</h5>
                    </div>
                    <div class="stats-card-body">
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <div class="stat-tile">
                                    <i class="bi bi-people-fill text-primary"></i>
                                    <div class="stat-num">@Model.QueueStudents.Count()</div>
                                    <div class="stat-label">Total Joined</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-tile">
                                    <i class="bi bi-hourglass-split text-warning"></i>
                                    <div class="stat-num">@Model.QueueStudents.Count(s => s.Status == "Pending")</div>
                                    <div class="stat-label">Waiting</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-tile">
                                    <i class="bi bi-person-check-fill" style="color: var(--green-dark);"></i>
                                    <div class="stat-num">@Model.QueueStudents.Count(s => s.Status == "Serving")</div>
                                    <div class="stat-label">Being Served</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="stat-tile">
                                    <i class="bi bi-check-circle-fill" style="color: var(--green);"></i>
                                    <div class="stat-num">@Model.QueueStudents.Count(s => s.Status == "Done")</div>
                                    <div class="stat-label">Completed</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Copy to clipboard
        document.querySelectorAll(".copy-btn").forEach(btn => {
            btn.addEventListener("click", function () {
                const textToCopy = this.dataset.copy;
                navigator.clipboard.writeText(textToCopy).then(() => {
                    const original = this.innerHTML;
                    this.innerHTML = "<i class='bi bi-check-lg'></i> Copied!";
                    this.style.background = "var(--green-gradient)";
                    this.style.color = "white";

                    setTimeout(() => {
                        this.innerHTML = original;
                        this.style.background = "";
                        this.style.color = "";
                    }, 2000);
                });
            });
        });

        // Form validation
        document.getElementById('editQueueForm').addEventListener('submit', function (e) {
            const maxStudents = parseInt(document.querySelector('[name="MaxStudents"]').value);
            const servingBatch = parseInt(document.querySelector('[name="ServingBatchSize"]').value);

            if (maxStudents < 1) {
                e.preventDefault();
                alert('Maximum students must be at least 1');
                return false;
            }

            if (servingBatch < 1 || servingBatch > 10) {
                e.preventDefault();
                alert('Serving batch size must be between 1 and 10');
                return false;
            }

            if (servingBatch > maxStudents) {
                e.preventDefault();
                alert('Serving batch size cannot exceed maximum students');
                return false;
            }
        });
    </script>
}

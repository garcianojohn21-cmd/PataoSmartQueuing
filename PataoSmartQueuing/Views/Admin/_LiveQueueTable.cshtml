@{
    var servingStudents = ViewBag.ServingStudents as List<PataoSmartQueuing.Models.QueueStudent>;
    var nextInLine = ViewBag.NextInLine as List<PataoSmartQueuing.Models.QueueStudent>;
}

<div class="row g-4">
    <!-- Currently Serving Section -->
    <div class="col-lg-6">
        <div class="serving-section text-center text-white">
            <h2 class="section-title">
                <i class="bi bi-person-check-fill me-3"></i>NOW SERVING
            </h2>

            @if (servingStudents != null && servingStudents.Any())
            {
                <div class="mt-4">
                    @foreach (var student in servingStudents)
                    {
                        <div class="number-display">
                            #@student.QueueNumber
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-hourglass-split empty-icon"></i>
                    <p class="waiting-text">WAITING FOR<br />NEW CUSTOMER</p>
                </div>
            }
        </div>
    </div>

    <!-- Next in Line Section -->
    <div class="col-lg-6">
        <div class="next-section">
            <h2 class="section-title text-center" style="color: var(--parakeet-dark);">
                <i class="bi bi-clock-history me-3"></i>NEXT IN LINE
            </h2>

            @if (nextInLine != null && nextInLine.Any())
            {
                <div class="mt-4">
                    @for (int i = 0; i < Math.Min(nextInLine.Count, 5); i++)
                    {
                        var student = nextInLine[i];
                        <div class="next-item d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success next-badge me-4">@(i + 1)</span>
                                <span class="next-number">#@student.QueueNumber</span>
                            </div>
                            <i class="bi bi-chevron-right" style="font-size: 4rem; color: var(--parakeet-light);"></i>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox empty-icon" style="color: var(--parakeet-light);"></i>
                    <p class="waiting-text" style="color: var(--parakeet-dark); opacity: 0.5;">WAITING FOR<br />NEW CUSTOMER</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    :root {
        --parakeet-primary: #00C851;
        --parakeet-secondary: #007E33;
        --parakeet-light: #69F0AE;
        --parakeet-dark: #00695C;
    }

    .serving-section {
        background: linear-gradient(135deg, #00C851 0%, #00E05D 100%);
        border-radius: 30px;
        padding: 60px 40px;
        height: calc(100vh - 280px);
        box-shadow: 0 15px 40px rgba(0, 200, 81, 0.4);
        animation: pulse-glow 3s infinite;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .next-section {
        background: linear-gradient(145deg, #ffffff 0%, #f8fff9 100%);
        border-radius: 30px;
        padding: 60px 40px;
        height: calc(100vh - 280px);
        border: 5px solid var(--parakeet-light);
        box-shadow: 0 10px 30px rgba(0, 200, 81, 0.2);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .number-display {
        font-size: 15rem;
        font-weight: 900;
        text-shadow: 6px 6px 12px rgba(0, 0, 0, 0.3);
        letter-spacing: -10px;
        line-height: 1;
        margin: 20px 0;
        animation: fadeIn 0.5s ease-in-out;
    }

    .next-number {
        font-size: 6rem;
        font-weight: 900;
        color: var(--parakeet-primary);
        text-shadow: 3px 3px 6px rgba(0, 200, 81, 0.2);
    }

    .section-title {
        font-size: 3.5rem;
        font-weight: 900;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: 5px;
    }

    .next-item {
        background: white;
        border-left: 8px solid var(--parakeet-primary);
        padding: 30px 40px;
        margin: 20px 0;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        transition: all 0.3s ease;
    }

        .next-item:hover {
            transform: translateX(15px);
            box-shadow: 0 12px 30px rgba(0, 200, 81, 0.3);
        }

    .next-badge {
        font-size: 2rem;
        padding: 15px 25px;
        border-radius: 15px;
    }

    .empty-state {
        padding: 80px 40px;
        text-align: center;
    }

    .empty-icon {
        font-size: 10rem;
        opacity: 0.4;
        margin-bottom: 30px;
    }

    .waiting-text {
        font-size: 4rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
    }

    @@keyframes pulse-glow {
        0%, 100%

    {
        box-shadow: 0 15px 40px rgba(0, 200, 81, 0.4);
    }

    50% {
        box-shadow: 0 20px 80px rgba(0, 200, 81, 0.7);
    }

    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: scale(0.9);
    }

    to {
        opacity: 1;
        transform: scale(1);
    }

    }
</style>
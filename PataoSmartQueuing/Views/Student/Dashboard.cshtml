@{
    ViewData["Title"] = "Student Dashboard";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

@Html.AntiForgeryToken()

<style>
    /* Uses layout's existing CSS variables — no conflicts */

    .dash-wrap {
        max-width: 480px;
        margin: 0 auto;
        padding: 0 4px 40px;
    }

    /* ── ALERTS ── */
    .sq-alert {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 13px 16px;
        border-radius: 12px;
        margin-bottom: 12px;
        font-size: 13.5px;
        font-weight: 500;
        line-height: 1.5;
        border: none;
        box-shadow: var(--shadow-sm);
    }

        .sq-alert i {
            font-size: 16px;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .sq-alert.ok {
            background: var(--green-pale);
            color: var(--navy);
            border-left: 4px solid var(--green);
        }

        .sq-alert.warn {
            background: #FEF9C3;
            color: #713F12;
            border-left: 4px solid #EAB308;
        }

        .sq-alert.err {
            background: #FEE2E2;
            color: #7F1D1D;
            border-left: 4px solid #EF4444;
        }

    /* ── EMPTY STATE CARD ── */
    .empty-card {
        background: var(--white);
        border-radius: 18px;
        border: 1.5px solid var(--border-green);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .empty-card-header {
        background: var(--nav-gradient);
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--white);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.5px;
        border-bottom: 2px solid rgba(34,197,94,0.35);
    }

    .empty-card-body {
        padding: 40px 28px 36px;
        text-align: center;
    }

    .empty-icon {
        width: 82px;
        height: 82px;
        background: var(--green-pale);
        border: 2px solid var(--border-green);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        margin: 0 auto 24px;
        animation: sq-float 4s ease-in-out infinite;
    }

    @@keyframes sq-float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }
    }

    .empty-card-body h2 {
        font-size: 22px;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 8px;
    }

    .empty-card-body p {
        font-size: 14px;
        color: var(--gray-600);
        line-height: 1.6;
        max-width: 270px;
        margin: 0 auto 28px;
    }

    /* ── BUTTONS ── */
    .sq-btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 15px;
        background: var(--green-gradient);
        color: var(--white);
        font-size: 14px;
        font-weight: 700;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.25s;
        box-shadow: 0 4px 14px rgba(34,197,94,0.3);
    }

        .sq-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(34,197,94,0.4);
            color: var(--white);
        }

    .sq-btn-ghost {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 13px;
        background: transparent;
        color: var(--navy);
        font-size: 14px;
        font-weight: 600;
        border: 1.5px solid var(--border-green);
        border-radius: 12px;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.25s;
        margin-top: 10px;
    }

        .sq-btn-ghost:hover {
            background: var(--green-hover);
            border-color: var(--green);
            color: var(--navy-light);
        }

    /* ── SECTION EYEBROW ── */
    .sq-eyebrow {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 1.4px;
        text-transform: uppercase;
        color: var(--gray-400);
        margin-bottom: 10px;
    }

    /* ── QUEUE NAME TAG ── */
    .sq-queue-tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--green-pale);
        border: 1.5px solid var(--border-green);
        color: var(--green-dark);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        padding: 7px 14px;
        border-radius: 20px;
        margin-bottom: 20px;
    }

    .sq-tag-dot {
        width: 7px;
        height: 7px;
        background: var(--green);
        border-radius: 50%;
        animation: sq-blink 2s ease-in-out infinite;
    }

    @@keyframes sq-blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* ── NUMBER CARDS ── */
    .sq-num-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 14px;
    }

    .sq-num-card {
        background: var(--white);
        border: 1.5px solid var(--border-green);
        border-radius: 16px;
        padding: 20px 14px 16px;
        text-align: center;
        box-shadow: var(--shadow-sm);
        transition: box-shadow 0.2s;
    }

        .sq-num-card:hover {
            box-shadow: var(--shadow);
        }

        .sq-num-card .nc-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--gray-400);
            margin-bottom: 8px;
        }

        .sq-num-card .nc-num {
            font-size: 48px;
            font-weight: 800;
            line-height: 1;
            color: var(--green-dark);
            letter-spacing: -1px;
        }

            .sq-num-card .nc-num.navy {
                color: var(--navy);
            }

        .sq-num-card .nc-sub {
            font-size: 10px;
            color: var(--gray-400);
            margin-top: 5px;
        }

    /* ── PIN CARD ── */
    .sq-pin-card {
        background: var(--white);
        border: 1.5px solid var(--border-green);
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 14px;
        box-shadow: var(--shadow-sm);
    }

    .sq-pin-label {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: var(--gray-400);
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 12px;
    }

        .sq-pin-label i {
            color: var(--green-dark);
            font-size: 13px;
        }

    .sq-pin-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .sq-pin-field {
        flex: 1;
        height: 50px;
        background: var(--off-white);
        border: 1.5px solid var(--gray-200);
        border-radius: 10px;
        display: flex;
        align-items: center;
        padding: 0 14px;
        gap: 9px;
    }

        .sq-pin-field i {
            color: var(--gray-400);
            font-size: 14px;
            flex-shrink: 0;
        }

    #pinCode {
        background: transparent;
        border: none;
        outline: none;
        color: var(--navy);
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 7px;
        width: 100%;
    }

    .sq-pin-btn {
        width: 50px;
        height: 50px;
        background: var(--off-white);
        border: 1.5px solid var(--gray-200);
        border-radius: 10px;
        color: var(--gray-400);
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        flex-shrink: 0;
    }

        .sq-pin-btn:hover {
            background: var(--green-pale);
            border-color: var(--border-green);
            color: var(--green-dark);
        }

    #copyFeedback {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--green-dark);
        text-align: center;
        margin-top: 8px;
        min-height: 18px;
    }

    /* ── DIVIDER ── */
    .sq-rule {
        height: 1px;
        background: var(--gray-200);
        margin: 18px 0;
    }

    /* ── NOTIFICATION CARD ── */
    .sq-notif-card {
        background: var(--white);
        border: 1.5px solid var(--border-green);
        border-radius: 16px;
        padding: 22px 18px;
        box-shadow: var(--shadow-sm);
    }

    .sq-notif-head {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 18px;
    }

    .sq-notif-icon {
        width: 50px;
        height: 50px;
        flex-shrink: 0;
        background: var(--green-gradient);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--white);
        font-size: 20px;
        box-shadow: 0 4px 12px rgba(34,197,94,0.3);
        animation: sq-bell 4s ease-in-out infinite;
    }

    @@keyframes sq-bell {
        0%, 85%, 100% {
            transform: rotate(0);
        }

        88% {
            transform: rotate(-12deg);
        }

        92% {
            transform: rotate(12deg);
        }

        96% {
            transform: rotate(-6deg);
        }
    }

    .sq-notif-head-text h4 {
        font-size: 16px;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 2px;
    }

    .sq-notif-head-text p {
        font-size: 12px;
        color: var(--gray-400);
    }

    .sq-notif-chips {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        margin-bottom: 18px;
    }

    .sq-notif-chip {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        font-weight: 500;
        color: var(--gray-600);
        background: var(--off-white);
        border: 1px solid var(--gray-200);
        border-radius: 9px;
        padding: 10px 11px;
    }

        .sq-notif-chip i {
            color: var(--green-dark);
            font-size: 13px;
            flex-shrink: 0;
        }

    #notificationStatus {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        margin-top: 10px;
        font-size: 12px;
        font-weight: 600;
        color: var(--gray-400);
        background: var(--off-white);
        border: 1px solid var(--gray-200);
        border-radius: 9px;
        padding: 10px 14px;
        text-align: center;
    }

        #notificationStatus.enabled {
            color: var(--green-dark);
            background: var(--green-pale);
            border-color: var(--border-green);
        }

    /* ── MODAL ── */
    #queueDoneModal .modal-content {
        border-radius: 18px !important;
        border: 1.5px solid var(--border-green) !important;
        overflow: hidden;
        box-shadow: var(--shadow-lg) !important;
    }

    .sq-modal-header {
        background: var(--nav-gradient);
        border-bottom: 2px solid rgba(34,197,94,0.35);
        padding: 16px 24px;
        text-align: center;
    }

        .sq-modal-header h5 {
            font-size: 17px;
            font-weight: 800;
            color: var(--white);
            margin: 0;
        }

    .sq-modal-body {
        background: var(--white);
        padding: 36px 28px 20px;
        text-align: center;
    }

    .sq-modal-check {
        width: 86px;
        height: 86px;
        background: var(--green-pale);
        border: 2px solid var(--border-green);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: 0 auto 20px;
    }

    .sq-modal-body h4 {
        font-size: 21px;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 8px;
    }

    .sq-modal-body p {
        font-size: 14px;
        color: var(--gray-600);
        margin-bottom: 5px;
    }

    #countdown {
        color: var(--green-dark);
        font-weight: 800;
    }

    .sq-modal-footer {
        background: var(--white);
        border-top: 1px solid var(--gray-200);
        padding: 16px 24px 22px;
        display: flex;
        justify-content: center;
    }
</style>

<div class="dash-wrap">

    @* ══ NO ACTIVE QUEUE ══ *@
    @if (ViewBag.QueueJoined == false || ViewBag.NoActiveQueue == true)
    {
        @if (ViewBag.JustServed == true)
        {
            <div class="sq-alert ok mb-3">
                <i class="bi bi-check-circle-fill"></i>
                <span>Successfully served in <strong>@ViewBag.QueueName</strong></span>
            </div>
        }
        @if (ViewBag.QueueDeleted == true)
        {
            <div class="sq-alert warn mb-3">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@ViewBag.Message</span>
            </div>
        }
        @if (ViewBag.WasUnserved == true)
        {
            <div class="sq-alert err mb-3">
                <i class="bi bi-x-circle-fill"></i>
                <span>@ViewBag.Message</span>
            </div>
        }

        <div class="empty-card">
            <div class="empty-card-header">
                <i class="bi bi-clipboard2-check-fill"></i> Queue Dashboard
            </div>
            <div class="empty-card-body">
                <div class="empty-icon">📋</div>
                <h2>No Active Queue</h2>
                <p>You're not in any queue right now. Join one to get your priority number and track your spot.</p>
                <a asp-action="JoinQueue" class="sq-btn-primary">
                    <i class="bi bi-plus-circle-fill"></i> Join a Queue
                </a>
                <a asp-action="History" class="sq-btn-ghost">
                    <i class="bi bi-clock-history"></i> View History
                </a>
            </div>
        </div>
    }

    @* ══ ACTIVE QUEUE ══ *@
    else
    {
        <div>
            <div class="sq-queue-tag">
                <div class="sq-tag-dot"></div>
                @ViewBag.QueueName
            </div>
        </div>

        <p class="sq-eyebrow">Your Status</p>
        <div class="sq-num-row">
            <div class="sq-num-card">
                <div class="nc-label">Your Number</div>
                <div class="nc-num" id="priorityNumber">#@ViewBag.PriorityNumber</div>
                <div class="nc-sub">Priority</div>
            </div>
            <div class="sq-num-card">
                <div class="nc-label">Now Serving</div>
                <div class="nc-num navy" id="nowServingDisplay">@ViewBag.CurrentServing</div>
                <div class="nc-sub">Current</div>
            </div>
        </div>

        <div class="sq-pin-card">
            <div class="sq-pin-label">
                <i class="bi bi-shield-lock-fill"></i> Security PIN
            </div>
            <div class="sq-pin-row">
                <div class="sq-pin-field">
                    <i class="bi bi-lock-fill"></i>
                    <input type="password" id="pinCode" value="@ViewBag.PinCode" readonly />
                </div>
                <button class="sq-pin-btn" type="button" onclick="togglePinVisibility()" title="Show/Hide">
                    <i class="bi bi-eye-fill" id="eyeIcon"></i>
                </button>
                <button class="sq-pin-btn" type="button" onclick="copyPinToClipboard()" title="Copy">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
            <span id="copyFeedback"></span>
        </div>

        <div class="sq-rule"></div>

        <div class="sq-notif-card">
            <div class="sq-notif-head">
                <div class="sq-notif-icon">
                    <i class="bi bi-bell-fill" id="mainNotificationIcon"></i>
                </div>
                <div class="sq-notif-head-text">
                    <h4>Stay Updated</h4>
                    <p>Instant alerts when it's almost your turn</p>
                </div>
            </div>
            <div class="sq-notif-chips">
                <div class="sq-notif-chip"><i class="bi bi-arrow-up-circle-fill"></i> Position updates</div>
                <div class="sq-notif-chip"><i class="bi bi-alarm-fill"></i> Turn reminders</div>
                <div class="sq-notif-chip"><i class="bi bi-megaphone-fill"></i> Announcements</div>
                <div class="sq-notif-chip"><i class="bi bi-lightning-fill"></i> Real-time alerts</div>
            </div>
            <button class="sq-btn-primary" id="enableNotificationsBtn" onclick="requestNotificationPermission()">
                <i class="bi bi-bell"></i> Enable Notifications
            </button>
            <div id="notificationStatus">
                <i class="bi bi-info-circle"></i> Tap above to enable
            </div>
        </div>
    }

</div>

<!-- QUEUE DONE MODAL -->
<div class="modal fade" id="queueDoneModal" tabindex="-1" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered mx-3">
        <div class="modal-content">
            <div class="sq-modal-header">
                <h5><i class="bi bi-check-circle-fill me-2"></i>Queue Completed!</h5>
            </div>
            <div class="sq-modal-body">
                <div class="sq-modal-check">🎉</div>
                <h4>Successfully Served!</h4>
                <p>You have been successfully served.</p>
                <p>Redirecting in <span id="countdown">3</span>s...</p>
            </div>
            <div class="sq-modal-footer">
                <a href="@Url.Action("History", "Student")" class="sq-btn-primary" style="width:auto; padding: 13px 28px;">
                    <i class="bi bi-clock-history"></i> View History
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePinVisibility() {
            var p = document.getElementById('pinCode');
            var e = document.getElementById('eyeIcon');
            if (!p || !e) return;
            if (p.type === 'password') {
                p.type = 'text';
                e.className = 'bi bi-eye-slash-fill';
            } else {
                p.type = 'password';
                e.className = 'bi bi-eye-fill';
            }
        }

        function copyPinToClipboard() {
            var p = document.getElementById('pinCode');
            var f = document.getElementById('copyFeedback');
            if (!p || !f) return;
            navigator.clipboard.writeText(p.value)
                .then(function () {
                    f.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Copied!';
                    setTimeout(function () { f.textContent = ''; }, 2000);
                })
                .catch(function () {
                    f.innerHTML = '<i class="bi bi-x-circle-fill me-1"></i>Failed to copy';
                    f.style.color = '#EF4444';
                    setTimeout(function () { f.textContent = ''; }, 2000);
                });
        }

        function checkNotificationPermission() {
            var s = document.getElementById('notificationStatus');
            var b = document.getElementById('enableNotificationsBtn');
            if (!s || !b) return;
            if (!('Notification' in window)) {
                s.innerHTML = '<i class="bi bi-x-circle me-1"></i>Not supported in this browser';
                b.disabled = true; return;
            }
            if (Notification.permission === 'granted') {
                updateNotificationButtonState(true);
                s.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Notifications enabled';
                s.classList.add('enabled');
            } else if (Notification.permission === 'denied') {
                s.innerHTML = '<i class="bi bi-x-circle me-1"></i>Blocked — enable in browser settings';
                b.disabled = true;
            }
        }

        function requestNotificationPermission() {
            if (!('Notification' in window)) { alert('Notifications not supported'); return; }
            Notification.requestPermission().then(function (perm) {
                var s = document.getElementById('notificationStatus');
                if (perm === 'granted') {
                    updateNotificationButtonState(true);
                    s.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Notifications enabled!';
                    s.classList.add('enabled');
                } else {
                    s.innerHTML = '<i class="bi bi-x-circle me-1"></i>Permission denied';
                }
            });
        }

        function updateNotificationButtonState(enabled) {
            var b = document.getElementById('enableNotificationsBtn');
            if (!b || !enabled) return;
            b.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Notifications Active';
            b.disabled = true;
            b.style.background = 'var(--green-pale)';
            b.style.color = 'var(--green-dark)';
            b.style.boxShadow = 'none';
        }

        document.addEventListener('DOMContentLoaded', function () {
            checkNotificationPermission();
        });
    </script>

    @if (ViewBag.QueueJoined == true)
    {
        <script>
            var notificationsEnabled = Notification.permission === 'granted';
        </script>
    }
}

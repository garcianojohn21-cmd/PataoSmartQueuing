@model PataoSmartQueuing.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Student Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --parakeet-green: #3DDC84;
        --parakeet-dark: #2AB366;
        --parakeet-light: #6FFFB0;
        --parakeet-pale: #E8FFF3;
    }

    .parakeet-card {
        background: linear-gradient(135deg, var(--parakeet-pale) 0%, #ffffff 100%);
        border: 3px solid var(--parakeet-green);
        box-shadow: 0 8px 32px rgba(61, 220, 132, 0.3) !important;
    }

    .parakeet-title {
        color: var(--parakeet-dark);
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(61, 220, 132, 0.1);
    }

    .parakeet-hr {
        border-top: 2px solid var(--parakeet-green);
        opacity: 0.3;
    }

    .input-group-text {
        background-color: var(--parakeet-green);
        color: white;
        border: 1px solid var(--parakeet-dark);
    }

    .form-control {
        border: 1px solid var(--parakeet-green);
    }

        .form-control:focus {
            border-color: var(--parakeet-dark);
            box-shadow: 0 0 0 0.2rem rgba(61, 220, 132, 0.25);
        }

    .form-check-input:checked {
        background-color: var(--parakeet-green);
        border-color: var(--parakeet-dark);
    }

    .btn-parakeet {
        background-color: var(--parakeet-green);
        border-color: var(--parakeet-dark);
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-parakeet:hover {
            background-color: var(--parakeet-dark);
            border-color: var(--parakeet-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(61, 220, 132, 0.4);
        }

        .btn-parakeet:disabled {
            background-color: #a0a0a0;
            border-color: #888888;
        }

    .parakeet-link {
        color: var(--parakeet-dark);
        font-weight: 600;
        text-decoration: none;
    }

        .parakeet-link:hover {
            color: var(--parakeet-green);
            text-decoration: underline;
        }

    .password-toggle {
        cursor: pointer;
        background-color: var(--parakeet-green);
        color: white;
        border: 1px solid var(--parakeet-dark);
        padding: 0.375rem 0.75rem;
    }

        .password-toggle:hover {
            background-color: var(--parakeet-dark);
        }

    .alert-parakeet {
        background-color: var(--parakeet-pale);
        border: 1px solid var(--parakeet-green);
        color: var(--parakeet-dark);
    }
</style>

<div class="card parakeet-card shadow-lg p-4 col-md-5 col-lg-4 mx-auto mt-5 rounded-3">
    <h3 class="text-center parakeet-title mb-3">Student Login</h3>
    <hr class="parakeet-hr" />
    <form asp-action="Login" method="post">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>

        <!-- Email -->
        <div class="input-group mb-3">
            <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
            <input asp-for="Email" class="form-control" placeholder="Email" />
        </div>
        <span asp-validation-for="Email" class="text-danger d-block mb-2"></span>

        <!-- Toggle: Password or Code -->
        <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="UseVerificationCode" asp-for="UseVerificationCode" />
            <label class="form-check-label" for="UseVerificationCode">Login using verification code</label>
        </div>

        <!-- Password Field with Eye Toggle -->
        <div class="input-group mb-3" id="passwordField">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input asp-for="Password" id="passwordInput" class="form-control" type="password" placeholder="Password" />
            <span class="password-toggle" id="togglePassword">
                <i class="bi bi-eye-fill" id="eyeIcon"></i>
            </span>
        </div>
        <span asp-validation-for="Password" class="text-danger d-block mb-2"></span>

        <!-- Verification Code Field -->
        <div class="input-group mb-3" id="codeField" style="display:none;">
            <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
            <input asp-for="VerificationCode" class="form-control" placeholder="Enter verification code" />
            <button type="button" class="btn btn-parakeet" id="getCodeBtn">Get Code</button>
        </div>
        <span asp-validation-for="VerificationCode" class="text-danger d-block mb-2"></span>

        <!-- Terms and Conditions -->
        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" required />
            <label class="form-check-label">
                I agree to the <a href="/Home/Terms" target="_blank" class="parakeet-link">Terms & Conditions</a>
            </label>
        </div>

        <button type="submit" class="btn btn-parakeet w-100">Login</button>

        <p class="text-center mt-3">
            Don't have an account? <a asp-action="Register" class="parakeet-link">Register</a>
        </p>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-parakeet mt-2">@TempData["Message"]</div>
        }
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const checkbox = document.getElementById("UseVerificationCode");
        const passwordField = document.getElementById("passwordField");
        const codeField = document.getElementById("codeField");
        const getCodeBtn = document.getElementById("getCodeBtn");
        const emailField = document.querySelector("input[name='Email']");
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("passwordInput");
        const eyeIcon = document.getElementById("eyeIcon");

        // Toggle between password and verification code
        checkbox.addEventListener("change", function () {
            passwordField.style.display = this.checked ? "none" : "flex";
            codeField.style.display = this.checked ? "flex" : "none";
        });

        // Password visibility toggle
        togglePassword.addEventListener("click", function () {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);

            // Toggle eye icon
            if (type === "password") {
                eyeIcon.classList.remove("bi-eye-slash-fill");
                eyeIcon.classList.add("bi-eye-fill");
            } else {
                eyeIcon.classList.remove("bi-eye-fill");
                eyeIcon.classList.add("bi-eye-slash-fill");
            }
        });

        // Get verification code
        getCodeBtn.addEventListener("click", async () => {
            const email = emailField.value.trim();
            if (!email) { alert("Enter your email first."); return; }

            try {
                const formData = new FormData();
                formData.append("email", email);

                const res = await axios.post('/Account/GetCode', formData);

                if (res.data.success) {
                    alert(res.data.message);
                    let countdown = 60;
                    getCodeBtn.disabled = true;
                    getCodeBtn.innerText = `Resend (${countdown}s)`;
                    const timer = setInterval(() => {
                        countdown--;
                        getCodeBtn.innerText = `Resend (${countdown}s)`;
                        if (countdown <= 0) {
                            clearInterval(timer);
                            getCodeBtn.disabled = false;
                            getCodeBtn.innerText = "Get Code";
                        }
                    }, 1000);
                } else {
                    alert(res.data.message);
                }
            } catch (err) {
                console.error("AXIOS ERROR:", err);
                alert("Error sending code.");
            }
        });
    </script>
}
@model PataoSmartQueuing.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Student Registration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --parakeet-green: #3DDC84;
        --parakeet-dark: #2AB366;
        --parakeet-light: #6FFFB0;
        --parakeet-pale: #E8FFF3;
    }

    .parakeet-card {
        background: linear-gradient(135deg, var(--parakeet-pale) 0%, #ffffff 100%);
        border: 3px solid var(--parakeet-green);
        box-shadow: 0 8px 32px rgba(61, 220, 132, 0.3) !important;
    }

    .parakeet-title {
        color: var(--parakeet-dark);
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(61, 220, 132, 0.1);
    }

    .parakeet-hr {
        border-top: 2px solid var(--parakeet-green);
        opacity: 0.3;
    }

    .input-group-text {
        background-color: var(--parakeet-green);
        color: white;
        border: 1px solid var(--parakeet-dark);
    }

    .form-control, .form-select {
        border: 1px solid var(--parakeet-green);
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--parakeet-dark);
            box-shadow: 0 0 0 0.2rem rgba(61, 220, 132, 0.25);
        }

    .form-check-input:checked {
        background-color: var(--parakeet-green);
        border-color: var(--parakeet-dark);
    }

    .btn-parakeet {
        background-color: var(--parakeet-green);
        border-color: var(--parakeet-dark);
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-parakeet:hover {
            background-color: var(--parakeet-dark);
            border-color: var(--parakeet-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(61, 220, 132, 0.4);
        }

        .btn-parakeet:disabled {
            background-color: #a0a0a0;
            border-color: #888888;
        }

    .btn-outline-parakeet {
        background-color: white;
        border: 2px solid var(--parakeet-green);
        color: var(--parakeet-dark);
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-outline-parakeet:hover {
            background-color: var(--parakeet-green);
            border-color: var(--parakeet-dark);
            color: white;
        }

        .btn-outline-parakeet:disabled {
            background-color: #f0f0f0;
            border-color: #a0a0a0;
            color: #888888;
        }

    .parakeet-link {
        color: var(--parakeet-dark);
        font-weight: 600;
        text-decoration: none;
    }

        .parakeet-link:hover {
            color: var(--parakeet-green);
            text-decoration: underline;
        }

    .password-toggle {
        cursor: pointer;
        background-color: var(--parakeet-green);
        color: white;
        border: 1px solid var(--parakeet-dark);
        padding: 0.375rem 0.75rem;
    }

        .password-toggle:hover {
            background-color: var(--parakeet-dark);
        }

    .form-label {
        color: var(--parakeet-dark);
        font-weight: 600;
    }

    .optional-badge {
        font-size: 0.75rem;
        font-weight: 400;
        color: #888;
        margin-left: 4px;
    }

    .lrn-counter {
        font-size: 0.75rem;
        color: #888;
        text-align: right;
        margin-top: 2px;
    }

        .lrn-counter.text-danger {
            color: #dc3545 !important;
        }

        .lrn-counter.text-success {
            color: var(--parakeet-dark) !important;
        }
</style>

<div class="card parakeet-card shadow-lg p-3 p-md-4 col-12 col-md-8 col-lg-6 mx-auto mt-3 mt-md-5 rounded-3">
    <h3 class="text-center parakeet-title mb-3">Student Registration</h3>
    <hr class="parakeet-hr" />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Register" method="post" id="registerForm">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <!-- Email + Get Code -->
        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                <input asp-for="Email" class="form-control" id="emailInput" placeholder="Enter your email" />
                <button type="button" id="getCodeBtn" class="btn btn-outline-parakeet">Get Code</button>
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <!-- Verification Code -->
        <div class="mb-3">
            <label class="form-label">Verification Code</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                <input asp-for="VerificationCode" class="form-control" placeholder="Enter verification code" />
            </div>
            <span asp-validation-for="VerificationCode" class="text-danger small"></span>
        </div>

        <!-- First Name -->
        <div class="mb-3">
            <label class="form-label">First Name</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input asp-for="FirstName" class="form-control" placeholder="First Name" />
            </div>
            <span asp-validation-for="FirstName" class="text-danger small"></span>
        </div>

        <!-- Middle Name (Optional) -->
        <div class="mb-3">
            <label class="form-label">
                Middle Name <span class="optional-badge">(Optional)</span>
            </label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input asp-for="MiddleName" class="form-control" placeholder="Middle Name (leave blank if none)" />
            </div>
        </div>

        <!-- Last Name -->
        <div class="mb-3">
            <label class="form-label">Last Name</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input asp-for="LastName" class="form-control" placeholder="Last Name" />
            </div>
            <span asp-validation-for="LastName" class="text-danger small"></span>
        </div>

        <!-- LRN -->
        <div class="mb-3">
            <label class="form-label">Learner Reference Number (LRN)</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-card-text"></i></span>
                <input asp-for="LRN"
                       class="form-control"
                       id="lrnInput"
                       placeholder="Enter your 12-digit LRN"
                       maxlength="12"
                       inputmode="numeric"
                       pattern="\d{12}"
                       oninput="this.value=this.value.replace(/\D/g,''); updateLrnCounter();" />
            </div>
            <div class="lrn-counter" id="lrnCounter">0 / 12 digits</div>
            <span asp-validation-for="LRN" class="text-danger small"></span>
        </div>

        <!-- Grade Level -->
        <div class="mb-3">
            <label class="form-label">Grade Level</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-mortarboard"></i></span>
                <select asp-for="GradeLevel" class="form-control">
                    <option value="">Select Grade Level</option>
                    <option value="Grade 11">Grade 11</option>
                    <option value="Grade 12">Grade 12</option>
                </select>
            </div>
            <span asp-validation-for="GradeLevel" class="text-danger small"></span>
        </div>

        <!-- Strand -->
        <div class="mb-3">
            <label class="form-label">Strand</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-journal"></i></span>
                <select asp-for="Strand" class="form-control">
                    <option value="">Select Strand</option>
                    <option value="STEM">STEM</option>
                    <option value="HUMSS">HUMSS</option>
                    <option value="ABM">ABM</option>
                    <option value="GAS">GAS</option>
                    <option value="TVL">TVL</option>
                </select>
            </div>
            <span asp-validation-for="Strand" class="text-danger small"></span>
        </div>

        <!-- Password with Eye Toggle -->
        <div class="mb-3">
            <label class="form-label">Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input asp-for="Password" type="password" id="passwordInput" class="form-control" placeholder="Min. 8 chars, 1 uppercase, 1 number" />
                <span class="password-toggle" id="togglePassword">
                    <i class="bi bi-eye-fill" id="eyeIcon"></i>
                </span>
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <!-- Confirm Password with Eye Toggle -->
        <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                <input asp-for="ConfirmPassword" type="password" id="confirmPasswordInput" class="form-control" placeholder="Confirm your password" />
                <span class="password-toggle" id="toggleConfirmPassword">
                    <i class="bi bi-eye-fill" id="eyeIconConfirm"></i>
                </span>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <!-- Terms -->
        <div class="form-check mb-3">
            <input asp-for="AcceptTerms" class="form-check-input" />
            <label asp-for="AcceptTerms" class="form-check-label">
                I agree to the <a href="/Home/Terms" target="_blank" class="parakeet-link">Terms &amp; Conditions</a>
            </label>
            <div>
                <span asp-validation-for="AcceptTerms" class="text-danger small"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-parakeet w-100 py-2">Register</button>
        <p class="text-center mt-3 mb-0">
            Already have an account? <a asp-action="Login" class="parakeet-link">Login</a>
        </p>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        const getCodeBtn = document.getElementById("getCodeBtn");
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("passwordInput");
        const eyeIcon = document.getElementById("eyeIcon");
        const toggleConfirmPassword = document.getElementById("toggleConfirmPassword");
        const confirmPasswordInput = document.getElementById("confirmPasswordInput");
        const eyeIconConfirm = document.getElementById("eyeIconConfirm");
        const lrnInput = document.getElementById("lrnInput");
        const lrnCounter = document.getElementById("lrnCounter");
        let countdown = 60;
        let timer;

        // LRN digit counter
        function updateLrnCounter() {
            const len = lrnInput.value.length;
            lrnCounter.textContent = `${len} / 12 digits`;
            lrnCounter.className = "lrn-counter";
            if (len === 12) {
                lrnCounter.classList.add("text-success");
            } else if (len > 0) {
                lrnCounter.classList.add("text-danger");
            }
        }

        // Get Code
        getCodeBtn.addEventListener("click", async () => {
            const email = document.getElementById("emailInput").value.trim();
            if (!email) {
                alert("Please enter your email first!");
                return;
            }

            try {
                const formData = new FormData();
                formData.append("email", email);

                const response = await axios.post("/Account/GetCode", formData);

                if (response.data.success) {
                    alert(response.data.message);
                    startCountdown();
                } else {
                    alert("Failed: " + response.data.message);
                }
            } catch (err) {
                console.error("AXIOS ERROR:", err);
                alert("Error sending code. Check console for details.");
            }
        });

        function startCountdown() {
            getCodeBtn.disabled = true;
            countdown = 60;
            getCodeBtn.innerText = `Resend (60s)`;

            timer = setInterval(() => {
                countdown--;
                if (countdown <= 0) {
                    clearInterval(timer);
                    getCodeBtn.disabled = false;
                    getCodeBtn.innerText = "Get Code";
                } else {
                    getCodeBtn.innerText = `Resend (${countdown}s)`;
                }
            }, 1000);
        }

        // Password toggle
        togglePassword.addEventListener("click", function () {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);
            eyeIcon.classList.toggle("bi-eye-fill");
            eyeIcon.classList.toggle("bi-eye-slash-fill");
        });

        // Confirm Password toggle
        toggleConfirmPassword.addEventListener("click", function () {
            const type = confirmPasswordInput.getAttribute("type") === "password" ? "text" : "password";
            confirmPasswordInput.setAttribute("type", type);
            eyeIconConfirm.classList.toggle("bi-eye-fill");
            eyeIconConfirm.classList.toggle("bi-eye-slash-fill");
        });
    </script>
}